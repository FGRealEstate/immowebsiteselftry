<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Objekt anfragen | Fischer & Geserich Real Estate</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { primary: "#08082F", secondary: "#D1B464", accent: "#D1B464", "page-bg": "#E9EEF0" }
        }
      }
    }
  </script>
</head>
<body class="insta-lock-page text-primary">
  <main class="min-h-screen flex items-center px-4 py-8">
    <div class="insta-lock-card bg-white grid grid-cols-1 lg:grid-cols-2">
      <section class="bg-primary text-white p-8 md:p-12 relative overflow-hidden">
        <div class="absolute inset-0 opacity-25"><img src="/images/berlinskypng.png" alt="Immobilie anfragen" class="w-full h-full object-cover"></div>
        <div class="relative z-10">
          <p class="text-secondary uppercase tracking-wide font-semibold text-sm mb-3">Exklusive Immobilienanfrage</p>
          <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">Fordern Sie die Objektinformationen direkt an.</h1>
          <p class="text-page-bg text-lg leading-relaxed mb-8">Diese Seite ist speziell für unsere Kampagne erstellt. Füllen Sie das Formular aus, wir melden uns persönlich mit den nächsten Schritten.</p>
          <div class="space-y-3 text-page-bg">
            <p><i class="fas fa-lock text-secondary mr-2"></i>Keine Navigation, keine Ablenkung</p>
            <p><i class="fas fa-user-check text-secondary mr-2"></i>Persönliche Prüfung Ihrer Anfrage</p>
            <p><i class="fas fa-bolt text-secondary mr-2"></i>Schnelle Rückmeldung</p>
          </div>
        </div>
      </section>

      <section class="p-8 md:p-12">
        <div class="mb-8">
          <p class="text-secondary uppercase tracking-wide font-semibold text-sm mb-2">Objektanfrage</p>
          <h2 class="text-3xl font-bold text-primary mb-3 js-title">Objekt unverbindlich anfragen</h2>
          <p class="text-gray-600 js-subtitle">Bitte geben Sie Ihre Kontaktdaten ein.</p>
        </div>

        <div class="insta-success hidden mb-5 rounded-lg bg-green-50 border border-green-300 text-green-800 p-4">
          Ihre Anfrage wurde übermittelt. Wir melden uns zeitnah persönlich.
        </div>
        <div class="insta-error hidden mb-5 rounded-lg bg-red-50 border border-red-300 text-red-800 p-4">
          Die Anfrage konnte nicht übermittelt werden.
        </div>

        <form class="insta-inquiry-form space-y-4">
          <input type="hidden" name="object_id">
          <input type="hidden" name="object_title">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input name="first_name" required class="lead-input" placeholder="Vorname *">
            <input name="last_name" required class="lead-input" placeholder="Nachname *">
          </div>
          <input type="email" name="email" required class="lead-input" placeholder="E-Mail-Adresse *">
          <input type="tel" name="phone" class="lead-input" placeholder="Telefonnummer">
          <select name="contact_preference" class="lead-select">
            <option value="E-Mail">Kontakt per E-Mail</option>
            <option value="Telefon">Kontakt per Telefon</option>
            <option value="WhatsApp">Kontakt per WhatsApp</option>
          </select>
          <textarea name="message" rows="5" class="lead-input" placeholder="Ihre Nachricht"></textarea>

          <label class="flex items-start gap-3 text-sm text-gray-700 bg-gray-50 border border-gray-200 rounded-lg p-4">
            <input type="checkbox" name="privacy_consent" value="true" required class="mt-1">
            <span>Ich habe die <a href="/datenschutz.html" target="_blank" class="font-bold text-primary hover:underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Angaben zur Bearbeitung meiner Anfrage zu. *</span>
          </label>

          <button type="submit" class="btn-85 w-full py-3 rounded-lg text-primary font-bold">Objekt anfragen</button>
        </form>
      </section>
    </div>
  </main>

<script>
(function(){
  const params = new URLSearchParams(location.search);
  const objectId = params.get("property_id") || params.get("object_id") || params.get("id") || "";
  const objectTitle = params.get("title") || "Instagram Objektanfrage";

  document.querySelectorAll('[name="object_id"]').forEach(el => el.value = objectId);
  document.querySelectorAll('[name="object_title"]').forEach(el => el.value = objectTitle);

  const title = document.querySelector(".js-title");
  if (title && objectTitle) title.textContent = objectTitle;

  document.querySelector(".insta-inquiry-form").addEventListener("submit", async function(e){
    e.preventDefault();

    const form = e.currentTarget;
    const success = document.querySelector(".insta-success");
    const error = document.querySelector(".insta-error");
    const button = form.querySelector('button[type="submit"]');

    success.classList.add("hidden");
    error.classList.add("hidden");
    button.disabled = true;
    button.textContent = "Wird übermittelt...";

    const fd = new FormData(form);

    try {
      const payload = {
        first_name: fd.get("first_name"),
        last_name: fd.get("last_name"),
        email: fd.get("email"),
        phone: fd.get("phone"),
        contact_preference: fd.get("contact_preference"),
        message: fd.get("message"),
        privacy_consent: fd.get("privacy_consent") === "true",
        object_id: fd.get("object_id"),
        object_title: fd.get("object_title"),
        source_url: location.href
      };

      const res = await fetch("/.netlify/functions/propstack-inquiry", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      const result = await res.json();
      if (!res.ok || !result.success) throw new Error(result.error || "Fehler");

      form.reset();
      success.classList.remove("hidden");
    } catch(err) {
      console.error(err);
      error.classList.remove("hidden");
    } finally {
      button.disabled = false;
      button.textContent = "Objekt anfragen";
    }
  });
})();
</script>
</body>
</html>
