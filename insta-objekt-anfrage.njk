  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: "#08082F",
            secondary: "#D1B464",
            accent: "#D1B464",
            cream: "#fffaf0"
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --fg-primary: #08082F;
      --fg-secondary: #D1B464;
      --fg-cream: #fffaf0;
      --fg-lightblue: #8fdcff;
    }

    html { scroll-behavior: smooth; }

    body.insta-premium-page {
      min-height: 100vh;
      margin: 0;
      background: #08082F;
      color: #fff;
      font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
      overflow-x: hidden;
    }

    .insta-bg {
      position: fixed;
      inset: 0;
      z-index: -3;
      background: radial-gradient(circle at 30% 15%, rgba(209,180,100,.28), transparent 28%), #08082F;
    }

    .insta-bg video,
    .insta-bg img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: .30;
      filter: saturate(.95) contrast(1.08);
    }

    .insta-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, rgba(8,8,47,.96) 0%, rgba(8,8,47,.82) 34%, rgba(8,8,47,.58) 100%),
        url('/images/background.svg');
      background-size: cover;
      opacity: .95;
      z-index: 1;
    }

    .insta-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(8,8,47,.34), rgba(8,8,47,.88));
      z-index: 2;
    }

    .mini-brand {
      position: fixed;
      top: 22px;
      left: 26px;
      z-index: 10;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: #fff;
      font-weight: 800;
      letter-spacing: .02em;
      text-decoration: none;
      text-shadow: 0 8px 24px rgba(0,0,0,.28);
    }

    .mini-brand img {
      width: 30px;
      height: 30px;
      object-fit: contain;
    }

    .campaign-shell {
      width: min(1240px, calc(100vw - 32px));
      min-height: 100vh;
      margin: 0 auto;
      padding: 104px 0 64px;
      display: grid;
      grid-template-columns: .86fr 1.14fr;
      gap: 36px;
      align-items: center;
    }

    .hero-panel {
      position: sticky;
      top: 90px;
      align-self: start;
      min-height: 680px;
      border: 1px solid rgba(209,180,100,.34);
      border-radius: 28px;
      overflow: hidden;
      background: linear-gradient(160deg, rgba(8,8,47,.96), rgba(26,24,68,.80));
      box-shadow: 0 34px 90px rgba(0,0,0,.36);
    }

    .hero-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      background: url('/images/berlinskypng.png') center bottom / cover no-repeat;
      opacity: .28;
      transform: scale(1.04);
    }

    .hero-panel::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(8,8,47,.25), rgba(8,8,47,.96)),
        radial-gradient(circle at 85% 22%, rgba(209,180,100,.22), transparent 28%);
    }

    .hero-content {
      position: relative;
      z-index: 2;
      padding: 54px 46px;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 44px;
    }

    .eyebrow {
      color: var(--fg-secondary);
      text-transform: uppercase;
      letter-spacing: .13em;
      font-weight: 900;
      font-size: .78rem;
      margin-bottom: 16px;
    }

    .hero-title {
      font-size: clamp(2.6rem, 4.3vw, 5.2rem);
      line-height: .98;
      font-weight: 900;
      letter-spacing: -.05em;
      color: #fff;
      margin: 0 0 24px;
    }

    .hero-copy {
      color: rgba(255,255,255,.78);
      font-size: 1.08rem;
      line-height: 1.75;
      max-width: 560px;
    }

    .trust-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .trust-card {
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.07);
      border-radius: 18px;
      padding: 18px;
      backdrop-filter: blur(12px);
    }

    .trust-card i { color: var(--fg-lightblue); font-size: 1.25rem; margin-bottom: 12px; }
    .trust-card strong { display:block; font-size: .98rem; color:#fff; margin-bottom: 5px; }
    .trust-card span { display:block; font-size: .83rem; color:rgba(255,255,255,.70); line-height:1.45; }

    .contact-strip {
      display:flex;
      flex-direction: column;
      gap:10px;
      color: rgba(255,255,255,.86);
      font-weight: 700;
    }
    .contact-strip i { width: 22px; color: var(--fg-lightblue); }

    .main-card {
      border: 1px solid rgba(209,180,100,.42);
      background: rgba(255,250,240,.94);
      color: var(--fg-primary);
      border-radius: 28px;
      overflow: hidden;
      box-shadow: 0 34px 100px rgba(0,0,0,.38);
      backdrop-filter: blur(22px);
    }

    .main-card-inner {
      padding: clamp(28px, 4vw, 52px);
      position: relative;
    }

    .main-card-inner::before {
      content: "";
      position:absolute;
      inset:0;
      pointer-events:none;
      background-image: linear-gradient(135deg, rgba(209,180,100,.07) 25%, transparent 25%, transparent 50%, rgba(209,180,100,.07) 50%, rgba(209,180,100,.07) 75%, transparent 75%);
      background-size: 22px 22px;
      opacity:.45;
    }

    .main-content { position:relative; z-index:1; }

    .step-label {
      display:inline-flex;
      align-items:center;
      gap: 8px;
      padding: 7px 14px;
      border-radius: 999px;
      color: var(--fg-lightblue);
      background: rgba(143,220,255,.13);
      border: 1px solid rgba(143,220,255,.24);
      text-transform: uppercase;
      font-size: .76rem;
      letter-spacing:.12em;
      font-weight: 900;
      margin-bottom: 18px;
    }

    .section-title {
      font-size: clamp(2rem, 3.1vw, 3.4rem);
      line-height: 1.03;
      font-weight: 900;
      letter-spacing: -.035em;
      margin:0 0 12px;
    }

    .section-copy {
      color: rgba(8,8,47,.68);
      line-height: 1.65;
      margin-bottom: 24px;
    }

    .progress-line {
      height: 7px;
      border-radius: 999px;
      background: rgba(8,8,47,.08);
      overflow: hidden;
      margin: 24px 0 30px;
    }
    .progress-line span {
      display:block;
      height:100%;
      width: 44%;
      background: linear-gradient(90deg, var(--fg-lightblue), var(--fg-secondary));
      border-radius:999px;
      transition: width .3s ease;
    }

    .property-grid {
      display:grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
      max-height: 520px;
      overflow:auto;
      padding-right: 6px;
    }

    .property-option {
      position: relative;
      display:block;
      cursor:pointer;
      border-radius: 18px;
      overflow:hidden;
      border: 1px solid rgba(8,8,47,.10);
      background:#fff;
      box-shadow: 0 12px 32px rgba(8,8,47,.08);
      transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
    }

    .property-option:hover {
      transform: translateY(-3px);
      border-color: rgba(209,180,100,.75);
      box-shadow: 0 18px 42px rgba(8,8,47,.14);
    }

    .property-option input { position:absolute; opacity:0; pointer-events:none; }

    .property-img {
      height: 162px;
      background:#10142e;
      position:relative;
      overflow:hidden;
    }

    .property-img img {
      width:100%;
      height:100%;
      object-fit:cover;
      transition: transform .35s ease;
    }

    .property-option:hover .property-img img { transform: scale(1.045); }

    .property-img::after {
      content:"";
      position:absolute;
      inset:0;
      background: linear-gradient(180deg, rgba(8,8,47,.05), rgba(8,8,47,.62));
    }

    .property-check {
      position:absolute;
      top: 12px;
      right: 12px;
      width: 34px;
      height: 34px;
      display:grid;
      place-items:center;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.56);
      background: rgba(8,8,47,.34);
      color:#fff;
      z-index:2;
      backdrop-filter: blur(10px);
      transition: all .18s ease;
    }

    .property-meta {
      position:absolute;
      left: 12px;
      bottom: 12px;
      display:flex;
      flex-wrap:wrap;
      gap:7px;
      z-index:2;
    }

    .pill {
      display:inline-flex;
      align-items:center;
      gap:5px;
      padding:5px 9px;
      border-radius:999px;
      background:rgba(255,255,255,.92);
      color:var(--fg-primary);
      font-size:.72rem;
      font-weight:900;
    }

    .property-body { padding: 16px; }
    .property-body h3 {
      font-size:1.05rem;
      line-height:1.25;
      font-weight:900;
      margin:0 0 9px;
      min-height: 2.6em;
    }

    .property-facts {
      display:flex;
      flex-wrap:wrap;
      gap:10px 14px;
      color:rgba(8,8,47,.62);
      font-weight:700;
      font-size:.86rem;
      margin-bottom: 12px;
    }

    .property-price {
      color: #9b740c;
      font-size: 1.12rem;
      font-weight: 950;
    }

    .property-option input:checked ~ .property-shell {
      outline: 3px solid rgba(209,180,100,.95);
      outline-offset: -3px;
    }
    .property-option input:checked ~ .property-shell .property-check {
      background: linear-gradient(135deg, #f7d46b, #ad7905);
      color:var(--fg-primary);
      border-color: rgba(255,255,255,.72);
    }

    .selected-bar {
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-top: 20px;
      padding: 14px 16px;
      border-radius: 16px;
      background: rgba(8,8,47,.06);
      border: 1px solid rgba(8,8,47,.08);
      color: rgba(8,8,47,.78);
      font-weight:800;
    }

    .premium-btn {
      border:0;
      border-radius: 14px;
      padding: 14px 22px;
      font-weight: 950;
      color: var(--fg-primary);
      background: linear-gradient(135deg, #f7dc7b, #bd8509);
      box-shadow: 0 14px 30px rgba(173,121,5,.28);
      cursor:pointer;
      transition: transform .18s ease, box-shadow .18s ease, opacity .18s ease;
    }
    .premium-btn:hover { transform: translateY(-2px); box-shadow:0 18px 38px rgba(173,121,5,.34); }
    .premium-btn:disabled { opacity:.5; cursor:not-allowed; transform:none; }

    .ghost-btn {
      border:1px solid rgba(8,8,47,.14);
      background:#fff;
      border-radius:14px;
      padding: 13px 19px;
      font-weight:900;
      color:var(--fg-primary);
      cursor:pointer;
    }

    .form-grid {
      display:grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap:14px;
    }

    .lead-input,
    .lead-select,
    .lead-textarea {
      width:100%;
      border:1px solid rgba(8,8,47,.14);
      border-radius:14px;
      background:rgba(255,255,255,.92);
      color:var(--fg-primary);
      padding: 15px 16px;
      font-family: inherit;
      font-weight:700;
      outline:none;
      transition:border-color .18s ease, box-shadow .18s ease, background .18s ease;
    }
    .lead-input:focus,
    .lead-select:focus,
    .lead-textarea:focus {
      border-color: rgba(209,180,100,.95);
      box-shadow:0 0 0 4px rgba(209,180,100,.16);
      background:#fff;
    }

    .lead-textarea { min-height: 118px; resize: vertical; }

    .consent-box {
      display:flex;
      align-items:flex-start;
      gap:12px;
      margin: 16px 0;
      padding: 15px 16px;
      border-radius:14px;
      background:rgba(255,255,255,.72);
      border:1px solid rgba(8,8,47,.10);
      color:rgba(8,8,47,.76);
      font-size:.9rem;
      line-height:1.45;
      font-weight:700;
    }

    .consent-box a { color:var(--fg-primary); font-weight:950; text-decoration:underline; }

    .selection-summary {
      margin: 0 0 18px;
      padding: 14px 16px;
      border-radius: 16px;
      background: rgba(8,8,47,.06);
      border: 1px solid rgba(8,8,47,.09);
    }
    .selection-summary strong { display:block; margin-bottom:8px; }
    .selection-summary ul { margin:0; padding-left:18px; color:rgba(8,8,47,.70); font-weight:700; line-height:1.55; }

    .status-box {
      margin-bottom:16px;
      padding: 15px 16px;
      border-radius: 16px;
      font-weight:800;
    }
    .status-success { background:#ecfdf3; border:1px solid #74e29b; color:#076b34; }
    .status-error { background:#fff1f2; border:1px solid #ffb3bb; color:#9f1239; }

    .hidden { display:none !important; }

    .empty-state {
      padding: 28px;
      border-radius: 18px;
      background: rgba(255,255,255,.80);
      border: 1px dashed rgba(8,8,47,.20);
      color: rgba(8,8,47,.70);
      line-height:1.6;
    }

    @media (max-width: 1024px) {
      .campaign-shell {
        grid-template-columns: 1fr;
        padding-top: 88px;
      }
      .hero-panel {
        position:relative;
        top:auto;
        min-height:auto;
      }
      .hero-content { padding: 38px 28px; }
      .trust-grid { grid-template-columns:1fr 1fr; }
    }

    @media (max-width: 720px) {
      .mini-brand span { display:none; }
      .campaign-shell { width:min(100% - 20px, 680px); padding-top:78px; }
      .hero-title { font-size:2.35rem; }
      .trust-grid,
      .property-grid,
      .form-grid { grid-template-columns:1fr; }
      .property-grid { max-height:none; }
      .selected-bar { align-items:stretch; flex-direction:column; }
      .premium-btn, .ghost-btn { width:100%; }
    }
  </style>
</head>

<body class="insta-premium-page">
  <div class="insta-bg" aria-hidden="true">
    <video autoplay muted loop playsinline poster="/images/berlinskypng.png">
      <source src="/videos/berlinsky.mp4" type="video/mp4">
    </video>
  </div>

  <a href="/" class="mini-brand" aria-label="Fischer & Geserich Real Estate">
    <img src="/images/Logogold.png" alt="Fischer & Geserich Real Estate">
    <span>Fischer &amp; Geserich Real Estate</span>
  </a>

  <main class="campaign-shell">
    <aside class="hero-panel">
      <div class="hero-content">
        <div>
          <p class="eyebrow">Exklusive Immobilienanfrage</p>
          <h1 class="hero-title">Fordern Sie ausgewählte Objektinformationen direkt an.</h1>
          <p class="hero-copy">
            Wählen Sie eine oder mehrere Immobilien aus unserer aktuellen Auswahl. Wir prüfen Ihre Anfrage persönlich und melden uns mit den passenden nächsten Schritten bei Ihnen.
          </p>
        </div>

        <div class="trust-grid">
          <div class="trust-card">
            <i class="fas fa-lock"></i>
            <strong>Diskrete Anfrage</strong>
            <span>Keine öffentliche Suche, keine unnötige Ablenkung.</span>
          </div>
          <div class="trust-card">
            <i class="fas fa-user-check"></i>
            <strong>Persönlich geprüft</strong>
            <span>Ihre Anfrage wird individuell durch unser Team eingeordnet.</span>
          </div>
          <div class="trust-card">
            <i class="fas fa-bolt"></i>
            <strong>Schnelle Rückmeldung</strong>
            <span>Wir melden uns zeitnah mit den verfügbaren Informationen.</span>
          </div>
          <div class="trust-card">
            <i class="fas fa-gem"></i>
            <strong>Premium Auswahl</strong>
            <span>Aktuelle Objekte und ausgewählte Off-Market-Hinweise.</span>
          </div>
        </div>

        <div class="contact-strip">
          <span><i class="fas fa-phone"></i> 01520 3083048</span>
          <span><i class="fas fa-envelope"></i> info@fg-realestate.de</span>
        </div>
      </div>
    </aside>

    <section class="main-card" id="anfrage">
      <div class="main-card-inner">
        <div class="main-content">
          <div id="stepObjects">
            <span class="step-label"><i class="fas fa-building"></i> Schritt 1 von 2</span>
            <h2 class="section-title">Welche Immobilie möchten Sie anfragen?</h2>
            <p class="section-copy">
              Wählen Sie bitte mindestens ein Objekt aus. Mehrfachauswahl ist möglich.
            </p>
            <div class="progress-line"><span style="width:50%"></span></div>

            {% if propstack.properties and propstack.properties.length %}
              <div class="property-grid" id="propertyGrid">
                {% for property in propstack.properties %}
                  <label class="property-option">
                    <input
                      type="checkbox"
                      class="js-property-choice"
                      value="{{ property.id }}"
                      data-id="{{ property.id }}"
                      data-title="{{ property.title | escape }}"
                      data-url="{{ property.url }}"
                      data-location="{{ property.location or '' | escape }}"
                      data-price="{{ property.price or 'Preis auf Anfrage' | escape }}"
                      data-type="{{ property.property_type or '' | escape }}"
                    >

                    <div class="property-shell">
                      <div class="property-img">
                        {% if property.main_image %}
                          <img src="{{ property.main_image }}" alt="{{ property.title | escape }}" loading="lazy">
                        {% else %}
                          <img src="/images/berlinskypng.png" alt="{{ property.title | escape }}" loading="lazy">
                        {% endif %}
                        <span class="property-check"><i class="fas fa-check"></i></span>
                        <div class="property-meta">
                          {% if property.marketing_type %}<span class="pill">{{ property.marketing_type }}</span>{% endif %}
                          {% if property.property_type %}<span class="pill">{{ property.property_type }}</span>{% endif %}
                        </div>
                      </div>

                      <div class="property-body">
                        <h3>{{ property.title }}</h3>
                        <div class="property-facts">
                          {% if property.location %}<span><i class="fas fa-location-dot"></i> {{ property.location }}</span>{% endif %}
                          {% if property.living_space %}<span><i class="fas fa-ruler-combined"></i> {{ property.living_space }}</span>{% endif %}
                          {% if property.rooms %}<span><i class="fas fa-bed"></i> {{ property.rooms }} Zi.</span>{% endif %}
                        </div>
                        <div class="property-price">{{ property.price or "Preis auf Anfrage" }}</div>
                      </div>
                    </div>
                  </label>
                {% endfor %}
              </div>
            {% else %}
              <div class="empty-state">
                Aktuell konnten keine öffentlichen Angebote geladen werden. Bitte hinterlassen Sie Ihre Kontaktdaten und nennen Sie die gewünschte Immobilie im Nachrichtenfeld.
              </div>
            {% endif %}

            <div class="selected-bar">
              <span id="selectedCount">Noch kein Objekt ausgewählt</span>
              <button class="premium-btn" id="continueToForm" type="button" disabled>Auswahl anfragen</button>
            </div>
          </div>

          <div id="stepForm" class="hidden">
            <span class="step-label"><i class="fas fa-envelope-open-text"></i> Schritt 2 von 2</span>
            <h2 class="section-title">Wohin dürfen wir die Informationen senden?</h2>
            <p class="section-copy">
              Ihre Anfrage wird persönlich geprüft. Anschließend erhalten Sie die nächsten Informationen zu den ausgewählten Immobilien.
            </p>
            <div class="progress-line"><span style="width:100%"></span></div>

            <div class="insta-success status-box status-success hidden">
              Ihre Anfrage wurde erfolgreich übermittelt. Wir melden uns zeitnah persönlich bei Ihnen.
            </div>
            <div class="insta-error status-box status-error hidden">
              Die Anfrage konnte nicht übermittelt werden. Bitte prüfen Sie Ihre Angaben oder versuchen Sie es erneut.
            </div>

            <div class="selection-summary">
              <strong>Ihre ausgewählten Immobilien:</strong>
              <ul id="selectionList"></ul>
            </div>

            <form class="insta-inquiry-form">
              <input type="hidden" name="object_id">
              <input type="hidden" name="object_title">
              <input type="hidden" name="selected_objects">

              <div class="form-grid">
                <input name="first_name" required class="lead-input" placeholder="Vorname *" autocomplete="given-name">
                <input name="last_name" required class="lead-input" placeholder="Nachname *" autocomplete="family-name">
              </div>

              <div class="form-grid" style="margin-top:14px;">
                <input type="email" name="email" required class="lead-input" placeholder="E-Mail-Adresse *" autocomplete="email">
                <input type="tel" name="phone" class="lead-input" placeholder="Telefonnummer" autocomplete="tel">
              </div>

              <div class="form-grid" style="margin-top:14px;">
                <select name="contact_preference" class="lead-select">
                  <option value="E-Mail">Kontakt bevorzugt per E-Mail</option>
                  <option value="Telefon">Kontakt bevorzugt per Telefon</option>
                  <option value="WhatsApp">Kontakt bevorzugt per WhatsApp</option>
                </select>
                <select name="urgency" class="lead-select">
                  <option value="Allgemeine Objektinformationen">Allgemeine Objektinformationen</option>
                  <option value="Exposé und Unterlagen">Exposé und Unterlagen</option>
                  <option value="Besichtigung gewünscht">Besichtigung gewünscht</option>
                  <option value="Diskrete Rückfrage">Diskrete Rückfrage</option>
                </select>
              </div>

              <textarea name="message" rows="5" class="lead-textarea" style="margin-top:14px;" placeholder="Ihre Nachricht, z. B. Rückrufwunsch, gewünschter Zeitraum oder konkrete Frage"></textarea>

              <label class="consent-box">
                <input type="checkbox" name="privacy_consent" value="true" required style="margin-top:4px;">
                <span>
                  Ich habe die <a href="/datenschutz/" target="_blank" rel="noopener">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Angaben zur Bearbeitung meiner Anfrage zu. *
                </span>
              </label>

              <div class="form-grid">
                <button type="button" class="ghost-btn" id="backToObjects">Zurück zur Auswahl</button>
                <button type="submit" class="premium-btn">Objektinformationen anfragen</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    (function(){
      const choices = Array.from(document.querySelectorAll('.js-property-choice'));
      const continueButton = document.getElementById('continueToForm');
      const selectedCount = document.getElementById('selectedCount');
      const stepObjects = document.getElementById('stepObjects');
      const stepForm = document.getElementById('stepForm');
      const selectionList = document.getElementById('selectionList');
      const backButton = document.getElementById('backToObjects');
      const form = document.querySelector('.insta-inquiry-form');
      const success = document.querySelector('.insta-success');
      const error = document.querySelector('.insta-error');

      function getSelectedObjects(){
        return choices
          .filter(choice => choice.checked)
          .map(choice => ({
            id: choice.dataset.id || choice.value,
            title: choice.dataset.title || 'Ausgewählte Immobilie',
            url: choice.dataset.url || '',
            location: choice.dataset.location || '',
            price: choice.dataset.price || '',
            type: choice.dataset.type || ''
          }));
      }

      function renderSelection(){
        const selected = getSelectedObjects();
        const count = selected.length;

        if (count === 0) {
          selectedCount.textContent = 'Noch kein Objekt ausgewählt';
          continueButton.disabled = true;
        } else if (count === 1) {
          selectedCount.textContent = '1 Objekt ausgewählt';
          continueButton.disabled = false;
        } else {
          selectedCount.textContent = count + ' Objekte ausgewählt';
          continueButton.disabled = false;
        }

        if (selectionList) {
          selectionList.innerHTML = selected.map(item => {
            const parts = [item.location, item.price].filter(Boolean).join(' · ');
            return '<li>' + escapeHtml(item.title) + (parts ? ' <span>(' + escapeHtml(parts) + ')</span>' : '') + '</li>';
          }).join('');
        }
      }

      choices.forEach(choice => choice.addEventListener('change', renderSelection));
      renderSelection();

      if (continueButton) {
        continueButton.addEventListener('click', function(){
          const selected = getSelectedObjects();
          if (!selected.length) return;

          form.querySelector('[name="object_id"]').value = selected[0].id;
          form.querySelector('[name="object_title"]').value = selected.map(item => item.title).join(' | ');
          form.querySelector('[name="selected_objects"]').value = JSON.stringify(selected);

          stepObjects.classList.add('hidden');
          stepForm.classList.remove('hidden');
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      if (backButton) {
        backButton.addEventListener('click', function(){
          stepForm.classList.add('hidden');
          stepObjects.classList.remove('hidden');
          success.classList.add('hidden');
          error.classList.add('hidden');
        });
      }

      if (form) {
        form.addEventListener('submit', async function(e){
          e.preventDefault();

          const selected = getSelectedObjects();
          if (!selected.length) {
            stepForm.classList.add('hidden');
            stepObjects.classList.remove('hidden');
            return;
          }

          const submitButton = form.querySelector('button[type="submit"]');
          const fd = new FormData(form);

          success.classList.add('hidden');
          error.classList.add('hidden');
          submitButton.disabled = true;
          submitButton.textContent = 'Wird übermittelt...';

          const readableSelection = selected.map((item, index) => {
            return (index + 1) + '. ' + item.title + '\n' +
              '   Objekt-ID: ' + item.id + '\n' +
              '   Ort: ' + (item.location || '-') + '\n' +
              '   Preis: ' + (item.price || '-') + '\n' +
              '   Link: ' + (location.origin + item.url);
          }).join('\n\n');

          const customerMessage = String(fd.get('message') || '').trim();
          const urgency = String(fd.get('urgency') || '').trim();

          const combinedMessage = [
            'Instagram Objektanfrage',
            '',
            'Ausgewählte Immobilien:',
            readableSelection,
            '',
            'Gewünschte Information:',
            urgency || '-',
            '',
            'Nachricht des Interessenten:',
            customerMessage || '-'
          ].join('\n');

          try {
            const payload = {
              first_name: fd.get('first_name'),
              last_name: fd.get('last_name'),
              email: fd.get('email'),
              phone: fd.get('phone'),
              contact_preference: fd.get('contact_preference'),
              message: combinedMessage,
              privacy_consent: fd.get('privacy_consent') === 'true',
              object_id: selected[0].id,
              object_title: selected.map(item => item.title).join(' | '),
              selected_objects: selected,
              source_url: location.href,
              campaign_source: 'Instagram Kampagne'
            };

            const res = await fetch('/.netlify/functions/propstack-inquiry', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });

            const result = await res.json().catch(() => ({}));
            if (!res.ok || !result.success) {
              throw new Error(result.error || 'Übermittlung fehlgeschlagen');
            }

            form.reset();
            choices.forEach(choice => choice.checked = false);
            renderSelection();
            selectionList.innerHTML = '';
            success.classList.remove('hidden');
          } catch(err) {
            console.error('INSTA OBJEKTANFRAGE FEHLER:', err);
            error.classList.remove('hidden');
          } finally {
            submitButton.disabled = false;
            submitButton.textContent = 'Objektinformationen anfragen';
          }
        });
      }

      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }
    })();
  </script>
</body>
</html>
