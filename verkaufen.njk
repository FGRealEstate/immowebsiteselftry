<section class="relative bg-primary py-20 md:py-32 overflow-hidden">
    <div class="container mx-auto px-4 text-center relative z-10">
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 text-white leading-tight">
            Immobilienverkauf mit <br>
            <span class="text-gold-gradient">Fischer & Geserich Real Estate</span>
        </h1>
        <p class="text-lg md:text-2xl font-light mb-10 text-secondary max-w-4xl mx-auto">
            Wir begleiten Eigentümer und Kapitalanleger beim professionellen Verkauf von Wohnimmobilien.
        </p>

        <a href="angebote.html" class="btn-85 inline-block py-3 px-8 text-lg font-bold rounded-lg shadow-xl hover:scale-105 transition-transform duration-300">
            Siehe dir unsere aktuellen Angebote an
        </a>
    </div>
</section>

<div id="kontakt-verkauf" class="bg-page-bg">
    {% set leadDefaultConcern = "Immobilie verkaufen" %}
    {% include "landingpage-lead.njk" %}
    {% set leadDefaultConcern = "" %}
</div>

<section class="py-24 bg-page-bg">
    <div class="container mx-auto px-4">
        <div class="text-center mb-20">
            <h2 class="text-3xl md:text-5xl font-bold text-primary italic leading-tight">Verkaufsprofil</h2>
            <p class="text-primary mt-4 font-medium tracking-widest uppercase text-sm">Fischer & Geserich Real Estate</p>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-5 gap-6 xl:gap-4 max-w-7xl mx-auto">
            {% set portfolio = [
                "Ein- & Zweifamilien&shy;häuser",
                "Eigentums&shy;wohnungen & Pakete",
                "Aufteilungs&shy;projekte",
                "Mehrfamilien- & Zins&shy;häuser",
                "Grundstücke"
            ] %}

            {% for item in portfolio %}
            <div class="bg-white p-8 md:p-10 shadow-sm border-t-4 border-accent flex flex-col items-center text-center justify-center min-h-[200px] xl:min-h-[320px] transition-transform duration-500 hover:-translate-y-1">
                <span class="text-gray-200 font-bold text-4xl mb-6 font-serif select-none">/0{{ loop.index }}</span>
                <h3 class="text-xl font-extrabold text-primary leading-tight [hyphens:manual] lang-de uppercase tracking-tight">
                    {{ item | safe }}
                </h3>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

