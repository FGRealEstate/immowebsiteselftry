<script>window.FG_LAB_DATA={"articles": [{"title": "Wie berechnet man die Eigenkapitalrendite?", "category": "Kapitalanlage", "summary": "Die Eigenkapitalrendite setzt den jährlichen Vermögenseffekt ins Verhältnis zum tatsächlich eingesetzten Eigenkapital.", "body": "Cashflow nach Steuer, Tilgung und – sofern bewusst berücksichtigt – Wertveränderung werden getrennt ausgewiesen. Entscheidend ist, keine Wertsteigerung als garantiert anzusehen und Nebenkosten sowie Anfangsinvestitionen vollständig zu erfassen."}, {"title": "Cashflow verstehen", "category": "Kapitalanlage", "summary": "Cashflow zeigt, welcher laufende Überschuss oder Zuschuss nach Miete, Kosten und Finanzierung verbleibt.", "body": "Ein positiver Cashflow ist nicht automatisch ein gutes Investment und ein negativer Cashflow nicht automatisch schlecht. Tilgung baut Vermögen auf, während Rücklagen, Mietausfall und Steuern die Liquidität beeinflussen."}, {"title": "Nicht umlagefähiges Hausgeld", "category": "Vermietung", "summary": "Nicht umlagefähige Bestandteile des Hausgelds trägt der Eigentümer selbst.", "body": "Typisch sind Verwalterkosten, Instandhaltungsanteile und bestimmte Gemeinschaftskosten. Für eine belastbare Kalkulation sollten Wirtschaftsplan und letzte Jahresabrechnung geprüft werden."}, {"title": "Wann lohnt sich ein Mehrfamilienhaus?", "category": "Immobilienkauf", "summary": "Ein Mehrfamilienhaus muss als Gesamtbetrieb aus Mieten, Kosten, Investitionen und Finanzierung betrachtet werden.", "body": "Neben der Anfangsrendite sind Mietstruktur, Leerstand, Capex, Genehmigungslage, Energiezustand und Exit-Fähigkeit wichtig. Ein einzelner Multiplikator reicht nicht."}, {"title": "AfA richtig berechnen", "category": "Steuern", "summary": "Die Abschreibung bezieht sich grundsätzlich auf den abschreibungsfähigen Gebäudeanteil, nicht auf den Bodenwert.", "body": "Kaufnebenkosten werden regelmäßig anteilig zugeordnet. Baujahr, Nutzung und steuerliche Einordnung bestimmen den Satz. Steuerliche Fragen gehören in die Prüfung mit dem Steuerberater."}, {"title": "Restnutzungsgutachten erklärt", "category": "Steuern", "summary": "Ein Restnutzungsgutachten kann unter Voraussetzungen eine kürzere tatsächliche Nutzungsdauer begründen.", "body": "Damit kann sich die jährliche AfA erhöhen. Das Gutachten muss fachlich belastbar sein; Anerkennung und individuelle Wirkung sind nicht garantiert."}, {"title": "Gebäudeanteil berechnen", "category": "Steuern", "summary": "Der Kaufpreis wird für steuerliche Zwecke auf Grund und Boden sowie Gebäude aufgeteilt.", "body": "Pauschale Prozentsätze können unpassend sein. Lage, Bodenrichtwert, Gebäudestandard und Ertragswertkomponenten beeinflussen die Aufteilung."}, {"title": "Annuitätendarlehen erklärt", "category": "Finanzierung", "summary": "Beim Annuitätendarlehen bleibt die Rate während der Zinsbindung regelmäßig konstant.", "body": "Der Zinsanteil sinkt mit der Restschuld, der Tilgungsanteil steigt. Die anfängliche Annuität ergibt sich aus Sollzins plus anfänglicher Tilgung bezogen auf die Darlehenssumme."}, {"title": "Tilgung oder Sondertilgung?", "category": "Finanzierung", "summary": "Höhere Tilgung reduziert die Restschuld schneller, bindet aber monatliche Liquidität.", "body": "Sondertilgungsrechte schaffen Flexibilität. Die richtige Struktur hängt von Cashflow, Zinsbindung, Rücklagen und alternativen Verwendungsmöglichkeiten des Kapitals ab."}, {"title": "5 % AfA – wann ist sie möglich?", "category": "Steuern", "summary": "Erhöhte Abschreibungssätze gelten nur bei bestimmten gesetzlichen Voraussetzungen.", "body": "Entscheidend sind Fertigstellung, Anschaffung, Nutzungsart und das jeweils geltende Steuerrecht. Der Rechner kann Szenarien zeigen, ersetzt aber keine steuerliche Prüfung."}, {"title": "§ 7b EStG im Überblick", "category": "Steuern", "summary": "Die Sonderabschreibung für Mietwohnungsneubau ist an Voraussetzungen und Grenzen gebunden.", "body": "Begünstigungszeitraum, Baukostenobergrenzen, Effizienzanforderungen und dauerhafte Vermietung müssen geprüft werden."}, {"title": "QNG und Effizienzhaus 40", "category": "Finanzierung", "summary": "QNG verbindet Nachhaltigkeitsanforderungen mit förderfähigen Gebäudestandards.", "body": "Bei Neubauten können Förderkredite und steuerliche Effekte relevant sein. Zertifizierungskosten, Bauqualität und Förderbedingungen gehören in die Gesamtkalkulation."}, {"title": "WEG-Rücklage verstehen", "category": "Vermietung", "summary": "Die Erhaltungsrücklage dient künftigen Maßnahmen am Gemeinschaftseigentum.", "body": "Eine niedrige Rücklage kann bei anstehenden Arbeiten zu Sonderumlagen führen. Protokolle, Beschlusssammlung und Instandhaltungsplan sind daher zentral."}, {"title": "Mietausfall kalkulieren", "category": "Kapitalanlage", "summary": "Mietausfall umfasst Leerstand, Zahlungsstörungen und nicht nahtlose Neuvermietung.", "body": "Ein pauschaler Ansatz von ein bis drei Prozent kann eine erste Orientierung sein; bei Gewerbe, möblierten Konzepten oder schwacher Nachfrage muss er objektspezifisch höher angesetzt werden."}, {"title": "Brutto- vs. Nettomietrendite", "category": "Kapitalanlage", "summary": "Die Bruttorendite teilt Jahresnettokaltmiete durch Kaufpreis. Die Nettorendite berücksichtigt laufende Eigentümerkosten.", "body": "Beide Kennzahlen sind vor Finanzierung. Für den Vergleich sollten Berechnungsbasis und Kostenabgrenzung identisch sein."}, {"title": "Kaufpreisfaktor richtig einordnen", "category": "Kapitalanlage", "summary": "Der Faktor ist Kaufpreis geteilt durch Jahresnettokaltmiete.", "body": "Er ist der Kehrwert der Bruttomietrendite und ignoriert Kosten, Finanzierung, Steuern und Investitionsbedarf. Er eignet sich nur als schneller Filter."}, {"title": "Beleihungsauslauf und Kondition", "category": "Finanzierung", "summary": "Der Beleihungsauslauf setzt das Darlehen ins Verhältnis zum bankseitigen Beleihungswert.", "body": "Er ist nicht identisch mit Kaufpreisfinanzierung. Höhere Ausläufe können die Kondition verteuern oder zusätzliche Sicherheiten erfordern."}, {"title": "Zinsbindung strategisch wählen", "category": "Finanzierung", "summary": "Die Zinsbindung verteilt Zinsänderungsrisiko und Flexibilität.", "body": "Kurze Bindungen können günstiger sein, erhöhen aber das Anschlussrisiko. Lange Bindungen schaffen Planbarkeit, können jedoch Aufschläge enthalten."}, {"title": "Anschlussfinanzierung planen", "category": "Finanzierung", "summary": "Entscheidend sind Restschuld, künftiger Zins und verbleibende Laufzeit.", "body": "Eine frühe Szenariorechnung zeigt, wie empfindlich die Rate auf Zinsänderungen reagiert. Forward-Darlehen sind eine Option, aber nicht immer wirtschaftlich."}, {"title": "Kaufnebenkosten vollständig erfassen", "category": "Immobilienkauf", "summary": "Grunderwerbsteuer, Notar, Grundbuch und gegebenenfalls Makler erhöhen den Kapitalbedarf.", "body": "Zusätzlich können Gutachten, Finanzierungskosten, Renovierung und Bereitstellungszinsen anfallen. Nicht jede Position ist in jedem Fall vorhanden."}, {"title": "Capex statt Schönrechnung", "category": "Kapitalanlage", "summary": "Größere Investitionen gehören getrennt von laufenden Kosten in die Planung.", "body": "Dach, Fassade, Heizung, Leitungen und energetische Maßnahmen können Renditen stark verändern. Ein technischer Plan über zehn bis zwanzig Jahre schafft Transparenz."}, {"title": "Mietsteigerungen realistisch modellieren", "category": "Vermietung", "summary": "Mietsteigerungen sind rechtlich und marktseitig begrenzt.", "body": "Bestandsmieten, Mietspiegel, Kappungsgrenzen, Modernisierung und Neuvermietung müssen getrennt betrachtet werden. Pauschale Wachstumsraten sind nur Szenarien."}, {"title": "Wertsteigerung als Szenario", "category": "Kapitalanlage", "summary": "Wertzuwachs ist unsicher und sollte nicht zur Rettung eines schwachen laufenden Cashflows dienen.", "body": "Sinnvoll sind konservative, Basis- und dynamische Szenarien. Beim Exit fallen außerdem Verkaufs- und gegebenenfalls Steuerkosten an."}, {"title": "Sensitivitätsanalyse nutzen", "category": "Kapitalanlage", "summary": "Eine Sensitivitätsanalyse zeigt, welche Annahmen das Ergebnis am stärksten verändern.", "body": "Typische Treiber sind Zins, Miete, Leerstand, Capex und Exit-Faktor. So wird sichtbar, wo die Due Diligence besonders tief sein muss."}, {"title": "Immobilien vergleichen", "category": "Immobilienkauf", "summary": "Zwei Objekte sollten mit denselben Annahmen und demselben Zeitraum verglichen werden.", "body": "Neben Rendite und Cashflow zählen Kapitalbindung, Restschuld, technisches Risiko, Mikrolage und Exit-Liquidität."}, {"title": "Steuerlicher Gewinn und echter Cashflow", "category": "Steuern", "summary": "Steuerlicher Gewinn und Liquiditätsüberschuss sind unterschiedliche Größen.", "body": "Tilgung ist Liquiditätsabfluss, aber keine Werbungskostenposition. AfA reduziert den steuerlichen Gewinn, ohne im Jahr der Abschreibung Liquidität zu kosten."}, {"title": "Umlagefähige Betriebskosten", "category": "Vermietung", "summary": "Umlagefähige Kosten können bei wirksamer Vereinbarung auf Mieter verteilt werden.", "body": "Der Eigentümer trägt dennoch Vorfinanzierung, Ausfallrisiko und nicht umlagefähige Anteile. Betriebskostenabrechnungen müssen formell und inhaltlich stimmen."}, {"title": "Instandhaltungsrücklage pro Quadratmeter", "category": "Kapitalanlage", "summary": "Ein pauschaler Ansatz kann für die erste Kalkulation helfen.", "body": "Gebäudealter, Zustand, Konstruktion und bereits vorhandene Rücklagen sind wichtiger als ein fixer Wert. Fünf bis fünfzehn Euro pro Quadratmeter und Jahr sind nur eine grobe Spannbreite."}, {"title": "Leerstand richtig bewerten", "category": "Vermietung", "summary": "Leerstand kann marktbedingt, technisch oder strategisch sein.", "body": "Bei Bestandsobjekten sind Dauer, Ursache, Renovierungsbedarf und realistische Neuvermietungsmiete zu prüfen."}, {"title": "Mikrolage vor Stadtname", "category": "Marktanalysen", "summary": "Straße, Block und fußläufige Umgebung sind oft wichtiger als die Stadt als Ganzes.", "body": "ÖPNV, Lärm, Nahversorgung, Arbeitgeber, Schulen, Quartiersentwicklung und Neubaupipeline beeinflussen Vermietbarkeit und Exit."}, {"title": "Due Diligence für Einsteiger", "category": "Immobilienkauf", "summary": "Eine strukturierte Prüfung umfasst Recht, Technik, Miete, Markt, Finanzierung und Steuern.", "body": "Der Rechner ist nur die wirtschaftliche Ebene. Dokumente und Annahmen müssen verifiziert werden."}, {"title": "Mietvertrag und Ertragssicherheit", "category": "Vermietung", "summary": "Die vertragliche Miete ist nur dann belastbar, wenn Vertrag und Zahlungshistorie geprüft sind.", "body": "Staffel, Index, Befristung, Nebenabreden und Kaution beeinflussen den Ertrag."}, {"title": "Indexmiete kalkulieren", "category": "Vermietung", "summary": "Indexmieten koppeln Anpassungen an den Verbraucherpreisindex.", "body": "Anpassungen erfolgen nicht automatisch und sind an formelle Vorgaben gebunden. Inflation und Zahlungsfähigkeit der Mieter sind getrennt zu betrachten."}, {"title": "Staffelmiete kalkulieren", "category": "Vermietung", "summary": "Staffelmieten machen künftige nominale Mieten planbarer.", "body": "Die Staffeln müssen wirksam vereinbart sein. Betriebskosten und Modernisierungsmöglichkeiten sind gesondert zu prüfen."}, {"title": "Sonderumlage als Risiko", "category": "Immobilienkauf", "summary": "Sonderumlagen können kurzfristig erhebliches Eigenkapital binden.", "body": "Beschlüsse, Protokolle, Rücklagenstand und bekannte Schäden sollten vor Kauf geprüft werden."}, {"title": "Energiezustand und Finanzierung", "category": "Finanzierung", "summary": "Energieeffizienz beeinflusst Betriebskosten, Investitionsbedarf, Förderfähigkeit und Bankbewertung.", "body": "Heizung, Gebäudehülle und Sanierungsfahrplan gehören in die Finanzierungsreserve."}, {"title": "Forward-Darlehen", "category": "Finanzierung", "summary": "Ein Forward-Darlehen sichert Zinsen vor Ablauf der bestehenden Bindung.", "body": "Dafür wird typischerweise ein Aufschlag bezahlt. Vorteil und Risiko hängen von Vorlaufzeit und Zinsentwicklung ab."}, {"title": "Bereitstellungszinsen", "category": "Finanzierung", "summary": "Nicht abgerufene Darlehensteile können nach einer bereitstellungsfreien Zeit Kosten verursachen.", "body": "Bei Neubau und Sanierung sollte der Auszahlungsplan zur Finanzierung passen."}, {"title": "Zinsänderungsstress testen", "category": "Finanzierung", "summary": "Ein guter Plan rechnet nicht nur mit dem heutigen Sollzins.", "body": "Szenarien mit plus ein, zwei oder drei Prozentpunkten zeigen die mögliche Anschlussrate und helfen bei der Wahl der Tilgung."}, {"title": "Eigenkapital optimal einsetzen", "category": "Finanzierung", "summary": "Mehr Eigenkapital senkt Darlehen und Risiko, kann aber die prozentuale Eigenkapitalrendite reduzieren.", "body": "Liquiditätsreserve und Opportunitätskosten sind ebenso wichtig wie die niedrigste Rate."}, {"title": "100-Prozent-Finanzierung", "category": "Finanzierung", "summary": "Bei einer 100-Prozent-Finanzierung wird regelmäßig der Kaufpreis finanziert, nicht automatisch jede Nebenkostenposition.", "body": "Bonität, Objektqualität, Beleihungswert und Rücklagen sind entscheidend. Die genaue Definition muss im Rechner ausgewählt werden."}, {"title": "110-Prozent-Finanzierung", "category": "Finanzierung", "summary": "Werden Kaufpreis und Nebenkosten finanziert, liegt das Darlehen über dem Kaufpreis.", "body": "Das erhöht Risiko, Zinsbelastung und mögliche Unterdeckung bei frühem Verkauf."}, {"title": "Exit-Kosten berücksichtigen", "category": "Kapitalanlage", "summary": "Beim Verkauf entstehen häufig Makler-, Rechts-, Vorfälligkeits- und Abwicklungskosten.", "body": "Der erwartete Verkaufspreis sollte daher nicht vollständig als Rückfluss angesetzt werden."}, {"title": "Spekulationsfrist im Überblick", "category": "Steuern", "summary": "Private Veräußerungsgewinne können innerhalb gesetzlicher Fristen steuerpflichtig sein.", "body": "Nutzung, Haltedauer und Struktur sind individuell zu prüfen. Gesellschaften folgen anderen Regeln."}, {"title": "Immobilien-GmbH oder Privatvermögen?", "category": "Steuern", "summary": "Die Rechtsform verändert Besteuerung, Finanzierung, Haftung und Exit.", "body": "Es gibt keine pauschal beste Struktur. Laufende Erträge, Veräußerung, Entnahmen und Verwaltungskosten gehören in den Vergleich."}, {"title": "Portfolio-Risiko messen", "category": "Kapitalanlage", "summary": "Mehrere Objekte reduzieren nicht automatisch Risiko.", "body": "Standort, Mietertyp, Finanzierung, Zinsbindung und technische Themen sollten diversifiziert und auf Portfolioebene gestresst werden."}, {"title": "DSCR verstehen", "category": "Finanzierung", "summary": "Der Debt Service Coverage Ratio vergleicht verfügbaren Objektüberschuss mit dem Schuldendienst.", "body": "Ein Wert über eins bedeutet rechnerische Deckung. Banken verwenden eigene Definitionen und Sicherheitsabschläge."}, {"title": "LTV verstehen", "category": "Finanzierung", "summary": "Loan-to-Value setzt Darlehen zum Immobilienwert oder Beleihungswert ins Verhältnis.", "body": "Je nach Kontext unterscheiden sich Nenner und Aussage. Für Vergleiche muss die Definition identisch sein."}, {"title": "IRR bei Immobilien", "category": "Kapitalanlage", "summary": "Der interne Zinsfuß berücksichtigt Zeitpunkt und Höhe aller Zahlungsströme.", "body": "Er ist sinnvoll für Haltedauer- und Exit-Vergleiche, reagiert aber stark auf den angenommenen Verkaufspreis."}, {"title": "Kapitalwert verstehen", "category": "Kapitalanlage", "summary": "Der Kapitalwert diskontiert künftige Zahlungsströme auf heute.", "body": "Der gewählte Diskontsatz ist eine zentrale Annahme und sollte Risiko sowie alternative Anlagechancen abbilden."}, {"title": "Mietmultiplikator und Faktor", "category": "Kapitalanlage", "summary": "Der Faktor beschreibt, wie viele Jahresnettokaltmieten dem Kaufpreis entsprechen.", "body": "Niedriger ist nicht automatisch besser, da Lage, Zustand, Entwicklung und Risiko nicht enthalten sind."}, {"title": "Bruttogeschossfläche vs. Wohnfläche", "category": "Immobilienkauf", "summary": "Flächenbegriffe sind nicht austauschbar.", "body": "Miete und Kaufpreis pro Quadratmeter sollten auf der richtigen, dokumentierten Fläche basieren."}, {"title": "Wohnflächenberechnung prüfen", "category": "Immobilienkauf", "summary": "Balkone, Dachschrägen und Nebenflächen werden je nach Regelwerk unterschiedlich berücksichtigt.", "body": "Flächenabweichungen können Wert, Miete und Finanzierung beeinflussen."}, {"title": "Ertragswertverfahren kompakt", "category": "Immobilienkauf", "summary": "Das Ertragswertverfahren leitet den Wert aus nachhaltig erzielbaren Erträgen ab.", "body": "Bewirtschaftungskosten, Bodenwert, Liegenschaftszins und Restnutzungsdauer sind zentrale Komponenten."}, {"title": "Sachwertverfahren kompakt", "category": "Immobilienkauf", "summary": "Das Sachwertverfahren betrachtet Herstellungskosten, Alterswertminderung und Marktanpassung.", "body": "Es wird häufig bei eigengenutzten oder schwer ertragsorientiert bewertbaren Objekten eingesetzt."}, {"title": "Vergleichswertverfahren kompakt", "category": "Immobilienkauf", "summary": "Vergleichspreise ähnlicher Objekte bilden die Grundlage.", "body": "Lage, Zustand, Größe, Rechte und Verkaufszeitpunkt müssen vergleichbar gemacht werden."}, {"title": "Bodenrichtwert richtig lesen", "category": "Marktanalysen", "summary": "Der Bodenrichtwert ist ein durchschnittlicher Lagewert für ein definiertes Gebiet.", "body": "Er ist kein automatischer Grundstückswert. Grundstückszuschnitt, Nutzung, Erschließung und wertrelevante Merkmale können abweichen."}, {"title": "Mietspiegel richtig nutzen", "category": "Vermietung", "summary": "Der Mietspiegel unterstützt die Einordnung ortsüblicher Vergleichsmieten.", "body": "Wohnwertmerkmale, Spanne und rechtlicher Anwendungsbereich müssen beachtet werden."}, {"title": "Modernisierungsumlage", "category": "Vermietung", "summary": "Bestimmte Modernisierungskosten können unter gesetzlichen Voraussetzungen teilweise umgelegt werden.", "body": "Abzüge, Kappungen, Härtefälle und formelle Anforderungen sind zu prüfen."}, {"title": "Finanzierungsreserve planen", "category": "Finanzierung", "summary": "Eine Reserve schützt vor Kostenüberschreitungen, Leerstand und verzögerten Auszahlungen.", "body": "Sie sollte nicht vollständig in den Kaufpreis fließen, sondern liquide verfügbar bleiben."}, {"title": "Deal-Screening in fünf Minuten", "category": "Kapitalanlage", "summary": "Ein schneller Check nutzt Kaufpreis, Jahresmiete, nicht umlagefähige Kosten, Zins und Tilgung.", "body": "Besteht der Deal den Schnelltest, folgt die vollständige Prüfung mit Dokumenten und Szenarien."}, {"title": "Vom Rechner zum Bankgespräch", "category": "Finanzierung", "summary": "Eine nachvollziehbare Kalkulation verbessert die Vorbereitung.", "body": "Banken benötigen zusätzlich Einkommens-, Vermögens-, Objekt- und Mietunterlagen sowie eigene Bewertungsannahmen."}], "lexicon": [{"term": "AfA", "definition": "Absetzung für Abnutzung: steuerliche Verteilung des abschreibungsfähigen Gebäudewerts über die Nutzungsdauer."}, {"term": "Anschlussfinanzierung", "definition": "Finanzierung der Restschuld nach Ablauf der Zinsbindung."}, {"term": "Annuität", "definition": "Regelmäßig gleichbleibende Rate aus Zins und Tilgung."}, {"term": "Ankaufsprüfung", "definition": "Strukturierte wirtschaftliche, rechtliche, technische und steuerliche Prüfung vor Kauf."}, {"term": "Angebotsmiete", "definition": "In Inseraten verlangte Miete; nicht identisch mit tatsächlich vereinbarter Bestandsmiete."}, {"term": "Ausfallwagnis", "definition": "Kalkulatorischer Abschlag für Leerstand und Zahlungsausfälle."}, {"term": "Beleihungsauslauf", "definition": "Verhältnis von Darlehen zu bankseitigem Beleihungswert."}, {"term": "Beleihungswert", "definition": "Vorsichtig ermittelter, langfristig erzielbarer Objektwert der Bank."}, {"term": "Bereitstellungszins", "definition": "Zins auf noch nicht abgerufene Darlehensteile nach einer Freiphase."}, {"term": "Bodenrichtwert", "definition": "Durchschnittlicher Bodenwert eines räumlich abgegrenzten Richtwertgebiets."}, {"term": "Bonität", "definition": "Einschätzung der Fähigkeit und Bereitschaft, Verpflichtungen zu erfüllen."}, {"term": "Bruttomietrendite", "definition": "Jahresnettokaltmiete geteilt durch Kaufpreis."}, {"term": "Bruttogrundfläche", "definition": "Gesamtheit bestimmter Grundflächen eines Bauwerks nach Norm."}, {"term": "Capex", "definition": "Größere, wert- oder nutzungsdauerrelevante Investitionen."}, {"term": "Cashflow", "definition": "Liquiditätsüberschuss oder -bedarf einer Periode."}, {"term": "Cash-on-Cash-Rendite", "definition": "Laufender Cashflow im Verhältnis zum eingesetzten Eigenkapital."}, {"term": "Courtage", "definition": "Maklervergütung."}, {"term": "Debt Service", "definition": "Summe aus Zins und Tilgung."}, {"term": "DSCR", "definition": "Verhältnis des zur Verfügung stehenden Überschusses zum Schuldendienst."}, {"term": "Due Diligence", "definition": "Systematische Prüfung eines Investments."}, {"term": "Eigenkapital", "definition": "Eigene Mittel, die in Kauf und Nebenkosten eingebracht werden."}, {"term": "Eigenkapitalrendite", "definition": "Vermögenseffekt oder Ertrag im Verhältnis zum eingesetzten Eigenkapital."}, {"term": "Erhaltungsrücklage", "definition": "Von einer WEG angesparte Mittel für Gemeinschaftseigentum."}, {"term": "Ertragswert", "definition": "Aus nachhaltig erzielbaren Erträgen abgeleiteter Wert."}, {"term": "Exit", "definition": "Geplanter Verkauf oder anderweitiger Ausstieg aus dem Investment."}, {"term": "Exit-Faktor", "definition": "Beim Verkauf angenommener Kaufpreisfaktor."}, {"term": "Finanzierungsquote", "definition": "Anteil einer gewählten Bezugsgröße, der durch Darlehen finanziert wird."}, {"term": "Forward-Darlehen", "definition": "Heute vereinbarte Anschlussfinanzierung mit späterer Auszahlung."}, {"term": "Fremdkapitalhebel", "definition": "Veränderung der Eigenkapitalrendite durch Einsatz von Fremdkapital."}, {"term": "Gebäudeanteil", "definition": "Anteil des Kaufpreises, der dem Gebäude statt Grund und Boden zugeordnet wird."}, {"term": "Gesamtinvestition", "definition": "Kaufpreis plus Nebenkosten und Anfangsinvestitionen."}, {"term": "Grunderwerbsteuer", "definition": "Landessteuer beim Erwerb inländischer Grundstücke."}, {"term": "Grundbuch", "definition": "Öffentliches Register der Grundstücksrechte."}, {"term": "Grundschuld", "definition": "Grundpfandrecht zur Kreditsicherung."}, {"term": "Hausgeld", "definition": "Monatliche Vorauszahlung des Wohnungseigentümers an die WEG."}, {"term": "Hebelwirkung", "definition": "Wirkung von Fremdkapital auf Eigenkapitalergebnis und Risiko."}, {"term": "Indexmiete", "definition": "Miete mit vertraglicher Kopplung an den Verbraucherpreisindex."}, {"term": "Instandhaltung", "definition": "Maßnahmen zum Erhalt des bestimmungsgemäßen Zustands."}, {"term": "Instandsetzung", "definition": "Wiederherstellung eines ordnungsgemäßen Zustands."}, {"term": "IRR", "definition": "Interner Zinsfuß eines Zahlungsstroms."}, {"term": "Jahresnettokaltmiete", "definition": "Summe der Nettokaltmieten eines Jahres."}, {"term": "Kapitaldienst", "definition": "Zins und Tilgung eines Darlehens."}, {"term": "Kapitalisierungszins", "definition": "Zinssatz zur Umrechnung künftiger Erträge in einen heutigen Wert."}, {"term": "Kapitalwert", "definition": "Barwert aller Ein- und Auszahlungen abzüglich Anfangsinvestition."}, {"term": "Kappungsgrenze", "definition": "Grenze für Mieterhöhungen innerhalb eines Zeitraums."}, {"term": "Kaufnebenkosten", "definition": "Zusätzliche Erwerbskosten neben dem Kaufpreis."}, {"term": "Kaufpreisfaktor", "definition": "Kaufpreis geteilt durch Jahresnettokaltmiete."}, {"term": "Leerstand", "definition": "Nicht vermietete Fläche oder Einheit."}, {"term": "Liegenschaftszins", "definition": "Marktüblicher Zinssatz im Ertragswertverfahren."}, {"term": "Liquiditätsreserve", "definition": "Sofort verfügbare Mittel für Unvorhergesehenes."}, {"term": "LTV", "definition": "Loan-to-Value: Darlehen im Verhältnis zu einem Objektwert."}, {"term": "Maklerprovision", "definition": "Vergütung für die Vermittlungs- oder Nachweistätigkeit."}, {"term": "Mietausfall", "definition": "Ausbleibender Mietertrag durch Leerstand oder Nichtzahlung."}, {"term": "Mietpreisbremse", "definition": "Gesetzliche Begrenzung der Wiedervermietungsmiete in bestimmten Gebieten."}, {"term": "Mietrendite", "definition": "Mietertrag im Verhältnis zu einer Wert- oder Kostenbasis."}, {"term": "Mietspiegel", "definition": "Übersicht ortsüblicher Vergleichsmieten."}, {"term": "Mietüberschuss", "definition": "Miete abzüglich objektspezifischer laufender Kosten."}, {"term": "Modernisierung", "definition": "Bauliche Verbesserung über reine Erhaltung hinaus."}, {"term": "Nachrangdarlehen", "definition": "Darlehen, dessen Gläubiger im Rang hinter andere Gläubiger tritt."}, {"term": "Nettomietrendite", "definition": "Jahresmiete abzüglich definierter Eigentümerkosten im Verhältnis zum Kaufpreis."}, {"term": "Nettovermögen", "definition": "Vermögenswert abzüglich Verbindlichkeiten; Definition im Modell beachten."}, {"term": "Nießbrauch", "definition": "Umfassendes Nutzungsrecht an einer Sache."}, {"term": "Nominalzins", "definition": "Vertraglicher Zinssatz ohne weitere Kosten."}, {"term": "Objektrendite", "definition": "Rendite des Objekts vor individueller Finanzierung."}, {"term": "Opportunitätskosten", "definition": "Entgangener Nutzen der besten nicht gewählten Alternative."}, {"term": "Operating Expenses", "definition": "Laufende Bewirtschaftungskosten."}, {"term": "Portfolio", "definition": "Gesamtheit mehrerer Investments."}, {"term": "Preis-Miet-Verhältnis", "definition": "Kaufpreis relativ zum laufenden Mietniveau."}, {"term": "Prolongation", "definition": "Verlängerung einer Finanzierung beim bisherigen Kreditgeber."}, {"term": "Restnutzungsdauer", "definition": "Voraussichtliche verbleibende wirtschaftliche Nutzungsdauer."}, {"term": "Restschuld", "definition": "Noch nicht zurückgezahlter Darlehensbetrag."}, {"term": "Risikopuffer", "definition": "Konservativer Abschlag oder Zuschlag zur Abdeckung von Unsicherheit."}, {"term": "Rücklage", "definition": "Für künftige Ausgaben reservierte Mittel."}, {"term": "Sachwert", "definition": "Aus Herstellungskosten und Bodenwert abgeleiteter Wert."}, {"term": "Sondertilgung", "definition": "Zusätzliche Tilgung außerhalb der regulären Rate."}, {"term": "Sonderumlage", "definition": "Zusätzliche Zahlung der Wohnungseigentümer aufgrund eines WEG-Beschlusses."}, {"term": "Spekulationsfrist", "definition": "Umgangssprachliche Bezeichnung für steuerlich relevante Haltefristen."}, {"term": "Staffelmiete", "definition": "Miete mit im Voraus vereinbarten Erhöhungsbeträgen."}, {"term": "Steuerlicher Überschuss", "definition": "Steuerlich ermittelte Einkünfte nach abzugsfähigen Aufwendungen."}, {"term": "Stress-Test", "definition": "Berechnung unter ungünstigeren Annahmen."}, {"term": "Tilgung", "definition": "Rückzahlung des Darlehenskapitals."}, {"term": "Tilgungssatz", "definition": "Anfänglicher oder laufender Anteil der Darlehensrückzahlung."}, {"term": "Total Return", "definition": "Gesamtertrag aus laufenden Zahlungen und Wertveränderung."}, {"term": "Transaktionskosten", "definition": "Kosten, die durch Erwerb oder Verkauf entstehen."}, {"term": "Umlagefähige Kosten", "definition": "Betriebskosten, die bei wirksamer Vereinbarung auf Mieter umgelegt werden können."}, {"term": "Unterdeckung", "definition": "Situation, in der Erlös oder Wert die Verbindlichkeiten nicht deckt."}, {"term": "Vervielfältiger", "definition": "Synonym für Kaufpreisfaktor."}, {"term": "Verkehrswert", "definition": "Marktwert nach den gesetzlichen Bewertungsgrundsätzen."}, {"term": "Vorfälligkeitsentschädigung", "definition": "Möglicher Ausgleich der Bank bei vorzeitiger Darlehensablösung."}, {"term": "Vollfinanzierung", "definition": "Finanzierung des Kaufpreises ohne Eigenkapitalanteil am Kaufpreis."}, {"term": "WEG", "definition": "Wohnungseigentümergemeinschaft."}, {"term": "Wertsteigerung", "definition": "Zunahme des Marktwerts; keine garantierte Größe."}, {"term": "Wirtschaftsplan", "definition": "Plan der WEG zu Einnahmen, Ausgaben und Vorschüssen."}, {"term": "Wohnfläche", "definition": "Nach einem Regelwerk ermittelte anrechenbare Fläche."}, {"term": "Werbungskosten", "definition": "Aufwendungen zur Erwerbung, Sicherung und Erhaltung steuerpflichtiger Einnahmen."}, {"term": "Zins", "definition": "Preis für die zeitweise Überlassung von Kapital."}, {"term": "Zinsbindung", "definition": "Zeitraum, für den der Sollzins fest vereinbart ist."}, {"term": "Zinsänderungsrisiko", "definition": "Risiko höherer Kosten bei künftiger Zinsanpassung."}, {"term": "Zinsdeckungsgrad", "definition": "Verhältnis von Ergebnisgröße zu Zinsaufwand."}, {"term": "Zinseszins", "definition": "Verzinsung bereits gutgeschriebener Zinsen."}, {"term": "Zwangsversteigerung", "definition": "Gerichtliches Verfahren zur Verwertung einer Immobilie."}, {"term": "Abgeschlossenheitsbescheinigung", "definition": "Bestätigung, dass Einheiten baulich abgeschlossen sind."}, {"term": "Baulast", "definition": "Öffentlich-rechtliche Verpflichtung eines Grundstückseigentümers."}, {"term": "Baunebenkosten", "definition": "Planungs-, Genehmigungs- und sonstige Kosten zusätzlich zu Bauleistungen."}, {"term": "Betriebskosten", "definition": "Laufende Kosten des bestimmungsgemäßen Gebrauchs."}, {"term": "Bewirtschaftungskosten", "definition": "Kosten für Verwaltung, Betrieb, Instandhaltung und Mietausfall."}, {"term": "Bodenwert", "definition": "Wert des unbebauten Grundstücks."}, {"term": "Erbbaurecht", "definition": "Zeitlich befristetes Recht, auf fremdem Grund ein Bauwerk zu haben."}, {"term": "Erbbauzins", "definition": "Regelmäßiges Entgelt für ein Erbbaurecht."}, {"term": "Flurstück", "definition": "Amtlich vermessener Teil der Erdoberfläche."}, {"term": "Gemeinschaftseigentum", "definition": "Teile einer WEG, die allen Eigentümern gemeinsam gehören."}, {"term": "Grundsteuer", "definition": "Laufende Steuer auf Grundbesitz."}, {"term": "Instandhaltungsstau", "definition": "Aufgeschobener Erhaltungsbedarf."}, {"term": "Kreditwürdigkeitsprüfung", "definition": "Prüfung von Einkommen, Vermögen, Verpflichtungen und Zahlungsverhalten."}, {"term": "Mietbindung", "definition": "Rechtliche Bindung von Miethöhe oder Belegung."}, {"term": "Miteigentumsanteil", "definition": "Rechnerischer Anteil am Gemeinschaftseigentum."}, {"term": "Nebenkostenabrechnung", "definition": "Abrechnung umlagefähiger Betriebskosten gegenüber Mietern."}, {"term": "Nominalrendite", "definition": "Rendite ohne Bereinigung um Inflation."}, {"term": "Reale Rendite", "definition": "Rendite nach Berücksichtigung der Inflation."}, {"term": "Sondereigentum", "definition": "Alleineigentum an bestimmten Räumen einer WEG."}, {"term": "Teilungserklärung", "definition": "Dokument zur Aufteilung eines Grundstücks in Wohnungs- oder Teileigentum."}, {"term": "Umwandlung", "definition": "Aufteilung eines Mietshauses in Wohnungseigentum."}, {"term": "Verwaltungskosten", "definition": "Kosten der kaufmännischen und technischen Verwaltung."}, {"term": "Wohnrecht", "definition": "Recht, Räume zu Wohnzwecken zu nutzen."}, {"term": "Zweckentfremdung", "definition": "Nutzung von Wohnraum zu anderen als Wohnzwecken unter rechtlichen Einschränkungen."}], "locations": [{"name": "Berlin", "region": "Metropole", "price": "Bestand häufig ca. 4.000–7.000 €/m²; starke Mikrolagenunterschiede", "rent": "Angebotsmieten häufig ca. 13–21 €/m²", "chance": "Tiefe Nachfrage, breite Arbeitgeberbasis, hohe Marktliquidität.", "risk": "Regulierung, hohe Einstiegspreise, heterogene Bezirke und hoher Prüfungsbedarf.", "infra": "Sehr dichtes ÖPNV-Netz, Universitäten, internatio