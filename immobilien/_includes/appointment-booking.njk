    border: 1px solid #fecaca;
    background: #fef2f2;
    color: #991b1b;
  }

  .appointment-quiz-section .hidden {
    display: none !important;
  }

  @media (max-width: 1024px) {
    .appointment-quiz-shell {
      grid-template-columns: 1fr;
    }

    .appointment-quiz-left {
      min-height: auto;
    }

    .appointment-note-card {
      margin-top: 1.4rem;
    }
  }

  @media (max-width: 720px) {
    .appointment-quiz-section {
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    .appointment-left-content,
    .appointment-quiz-right {
      padding: 1.3rem;
    }

    .appointment-slots-head {
      display: block;
    }

    .appointment-selected-date {
      margin-top: 0.8rem;
    }

    .appointment-slot-list {
      grid-template-columns: 1fr;
    }

    .appointment-calendar-weekdays,
    .appointment-calendar-grid {
      gap: 0.3rem;
    }

    .appointment-day {
      border-radius: 0.62rem;
      font-size: 0.82rem;
    }

    .appointment-calendar-footer {
      display: block;
    }

    .appointment-today-button {
      margin-top: 0.75rem;
      width: 100%;
    }
  }
</style>

<script>
(function () {
  function ready(fn) {
    if (document.readyState !== "loading") fn();
    else document.addEventListener("DOMContentLoaded", fn);
  }

  ready(function () {
    document.querySelectorAll(".appointment-quiz-section").forEach(initAppointmentQuiz);
  });

  function initAppointmentQuiz(section) {
    let step = 1;
    let calendarDate = new Date();
    let selectedDate = "";

    const form = section.querySelector(".appointment-quiz-form");
    const steps = Array.from(section.querySelectorAll(".appointment-quiz-step"));
    const preview = Array.from(section.querySelectorAll(".appointment-preview-item"));
    const current = section.querySelector(".appointment-current-step");
    const title = section.querySelector(".appointment-step-title");
    const progress = section.querySelector(".appointment-progress span");
    const back = section.querySelector(".appointment-back");
    const next = section.querySelector(".appointment-next");
    const submit = section.querySelector(".appointment-submit");
    const success = section.querySelector(".appointment-success");
    const error = section.querySelector(".appointment-error");
    const source = form.querySelector('input[name="source_url"]');
    const topicInput = form.querySelector('input[name="topic"]');
    const dateHidden = form.querySelector('input[name="date"]');
    const timeHidden = form.querySelector('input[name="time"]');
    const slotList = section.querySelector(".appointment-slot-list");
    const selectedDateText = section.querySelector(".appointment-selected-date-text");
    const calendarTitle = section.querySelector(".appointment-calendar-title");
    const calendarGrid = section.querySelector(".appointment-calendar-grid");
    const dateOutput = section.querySelector(".appointment-date-output");

    const titles = {
      1: "Welche Beratung wünschen Sie?",
      2: "An welchem Tag passt es Ihnen?",
      3: "Welche Uhrzeit passt Ihnen?",
      4: "Wie erreichen wir Sie?",
      5: "Worum geht es konkret?"
    };

    const monthNames = [
      "Januar", "Februar", "März", "April", "Mai", "Juni",
      "Juli", "August", "September", "Oktober", "November", "Dezember"
    ];

    const fallbackSlots = [
      { time: "09:00", label: "09:00–10:00" },
      { time: "10:00", label: "10:00–11:00" },
      { time: "11:00", label: "11:00–12:00" },
      { time: "14:00", label: "14:00–15:00" },
      { time: "15:00", label: "15:00–16:00" },
      { time: "16:00", label: "16:00–17:00" }
    ];

    if (source) source.value = window.location.href;

    function show(nextStep) {
      step = nextStep;

      steps.forEach(el => el.classList.toggle("hidden", Number(el.dataset.step) !== step));
      preview.forEach(el => el.classList.toggle("is-active", Number(el.dataset.previewStep) === step));

      current.textContent = String(step);
      title.textContent = titles[step] || titles[1];
      progress.style.width = (step / 5 * 100) + "%";

      back.classList.toggle("hidden", step === 1);
      next.classList.toggle("hidden", step === 5);
      submit.classList.toggle("hidden", step !== 5);
    }

    function pad(number) {
      return String(number).padStart(2, "0");
    }

    function toDateValue(date) {
      return date.getFullYear() + "-" + pad(date.getMonth() + 1) + "-" + pad(date.getDate());
    }

    function formatDateGerman(dateValue) {
      if (!dateValue) return "Datum ausgewählt";
      const parts = dateValue.split("-");
      if (parts.length !== 3) return dateValue;
      return parts[2] + "." + parts[1] + "." + parts[0];
    }

    function sameDay(a, b) {
      return a.getFullYear() === b.getFullYear() &&
        a.getMonth() === b.getMonth() &&
        a.getDate() === b.getDate();
    }

    function renderCalendar() {
      const year = calendarDate.getFullYear();
      const month = calendarDate.getMonth();
      const today = new Date();
      today.setHours(0, 0, 0, 0);

      calendarTitle.textContent = monthNames[month] + " " + year;
      calendarGrid.innerHTML = "";

      const first = new Date(year, month, 1);
      const mondayIndex = (first.getDay() + 6) % 7;
      const gridStart = new Date(year, month, 1 - mondayIndex);

      for (let i = 0; i < 42; i++) {
        const day = new Date(gridStart);
        day.setDate(gridStart.getDate() + i);
        day.setHours(0, 0, 0, 0);

        const value = toDateValue(day);
        const button = document.createElement("button");
        button.type = "button";
        button.className = "appointment-day";
        button.textContent = String(day.getDate());
        button.dataset.date = value;

        if (day.getMonth() !== month) button.classList.add("is-other-month");
        if (sameDay(day, today)) button.classList.add("is-today");
        if (selectedDate === value) button.classList.add("is-selected");

        const isPast = day < today;
        const isSunday = day.getDay() === 0;

        if (isPast || isSunday) {
          button.disabled = true;
        }

        button.addEventListener("click", function () {
          selectedDate = value;
          dateHidden.value = value;
          timeHidden.value = "";
          dateOutput.textContent = formatDateGerman(value);
          selectedDateText.textContent = formatDateGerman(value);
          renderCalendar();
          loadAvailability(value);
        });

        calendarGrid.appendChild(button);
      }
    }

    function normalizeSlot(slot) {
      if (typeof slot === "string") {
        const cleaned = slot.replace(" Uhr", "").trim();
        const start = cleaned.split(/[–-]/)[0].trim();
        return { time: start, label: cleaned.includes("-") || cleaned.includes("–") ? cleaned : start + " Uhr" };
      }

      const time = slot && slot.time ? String(slot.time).trim() : "";
      const label = slot && slot.label ? String(slot.label).trim() : time + " Uhr";
      return { time, label };
    }

    function renderSlots(slots) {
      slotList.innerHTML = "";

      const normalized = (slots || []).map(normalizeSlot).filter(slot => slot.time);

      if (!normalized.length) {
        slotList.innerHTML = '<button type="button" class="appointment-slot-placeholder" disabled>Keine freien Zeiten gefunden</button>';
        return;
      }

      normalized.forEach(slot => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "appointment-slot";
        btn.textContent = slot.label;
        btn.dataset.time = slot.time;

        btn.addEventListener("click", function () {
          section.querySelectorAll(".appointment-slot").forEach(b => b.classList.remove("is-selected"));
          btn.classList.add("is-selected");
          timeHidden.value = slot.time;
        });

        slotList.appendChild(btn);
      });
    }

    async function loadAvailability(date) {
      if (!date) {
        slotList.innerHTML = '<button type="button" class="appointment-slot-placeholder" disabled>Bitte zuerst ein Datum wählen</button>';
        return;
      }

      slotList.innerHTML = '<button type="button" class="appointment-slot-placeholder" disabled>Freie Zeiten werden geladen...</button>';

      try {
        const res = await fetch("/.netlify/functions/propstack-appointment-availability?date=" + encodeURIComponent(date));
        const data = await res.json();

        if (!res.ok || data.success === false) {
          throw new Error(data.error || "Verfügbarkeit konnte nicht geladen werden.");
        }

        renderSlots(data.slots || []);
      } catch (err) {
        console.warn("Availability fallback:", err.message);
        renderSlots(fallbackSlots);
      }
    }

    section.querySelector(".appointment-prev-month").addEventListener("click", function () {
      calendarDate = new Date(calendarDate.getFullYear(), calendarDate.getMonth() - 1, 1);
      renderCalendar();
    });

    section.querySelector(".appointment-next-month").addEventListener("click", function () {
      calendarDate = new Date(calendarDate.getFullYear(), calendarDate.getMonth() + 1, 1);
      renderCalendar();
    });

    section.querySelector(".appointment-today-button").addEventListener("click", function () {
      const today = new Date();
      calendarDate = new Date(today.getFullYear(), today.getMonth(), 1);
      selectedDate = toDateValue(today);
      dateHidden.value = selectedDate;
      timeHidden.value = "";
      dateOutput.textContent = formatDateGerman(selectedDate);
      selectedDateText.textContent = formatDateGerman(selectedDate);
      renderCalendar();
      loadAvailability(selectedDate);
    });

    section.querySelectorAll(".appointment-choice").forEach(btn => {
      btn.addEventListener("click", function () {
        section.querySelectorAll(".appointment-choice").forEach(b => b.classList.remove("is-selected"));
        btn.classList.add("is-selected");
        topicInput.value = btn.dataset.value || "";
        show(2);
      });
    });

    next.addEventListener("click", function () {
      if (step === 1 && !topicInput.value) return;

      if (step === 2) {
        if (!dateHidden.value) return;
        loadAvailability(dateHidden.value);
      }

      if (step === 3) {
        if (!timeHidden.value) {
          const first = section.querySelector(".appointment-slot:not([disabled])");
          if (first) first.focus();
          return;
        }
      }

      if (step < 5) show(step + 1);
    });

    back.addEventListener("click", function () {
      if (step > 1) show(step - 1);
    });

    form.addEventListener("submit", async function (event) {
      event.preventDefault();

      success.classList.add("hidden");
      error.classList.add("hidden");
      submit.disabled = true;
      submit.textContent = "Wird übermittelt...";

      const fd = new FormData(form);

      const payload = {
        first_name: fd.get("first_name"),
        last_name: fd.get("last_name"),
        email: fd.get("email"),
        phone: fd.get("phone"),
        preferred_date: fd.get("date"),
        preferred_time: fd.get("time"),
        date: fd.get("date"),
        time: fd.get("time"),
        address: fd.get("location"),
        location: fd.get("location"),
        appointment_type: fd.get("topic"),
        topic: fd.get("topic"),
        message: fd.get("message"),
        source_url: window.location.href,
        privacy_consent: fd.get("privacy_consent") === "true"
      };

      try {
        const res = await fetch("/.netlify/functions/propstack-appointment", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const result = await res.json();

        if (!res.ok || !result.success) {
          throw new Error(result.error || "Termin konnte nicht gespeichert werden.");
        }

        form.reset();
        topicInput.value = "";
        dateHidden.value = "";
        timeHidden.value = "";
        selectedDate = "";
        dateOutput.textContent = "Noch kein Datum gewählt";
        selectedDateText.textContent = "Datum ausgewählt";
        slotList.innerHTML = '<button type="button" class="appointment-slot-placeholder" disabled>Bitte zuerst ein Datum wählen</button>';
        if (source) source.value = window.location.href;
        section.querySelectorAll(".appointment-choice,.appointment-slot").forEach(b => b.classList.remove("is-selected"));
        renderCalendar();
        success.classList.remove("hidden");
        show(1);
        success.scrollIntoView({ behavior: "smooth", block: "center" });
      } catch (err) {
        console.error(err);
        error.classList.remove("hidden");
        error.scrollIntoView({ behavior: "smooth", block: "center" });
      } finally {
        submit.disabled = false;
        submit.textContent = "Terminwunsch senden";
      }
    });

    renderCalendar();
    show(1);
  }
})();
</script>
