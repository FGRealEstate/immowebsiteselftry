---
layout: base.njk
pagination:
  data: labContent.lexicon
  size: 1
  alias: entry
permalink: "lexikon/{{ entry.slug }}/index.html"
eleventyComputed:
  title: "{{ entry.term }} – Immobilienlexikon"
  description: "{{ entry.definition }}"
---
<main class="content-detail shell"><nav class="breadcrumbs"><a href="/investment-lab.html">Investment Lab</a><span>›</span><a href="/investment-lab.html#lexikon">Lexikon</a><span>›</span><span>{{ entry.term }}</span></nav><article class="science-article"><header><span class="lab-kicker">IMMOBILIENLEXIKON</span><h1>{{ entry.term }}</h1><p class="lead">{{ entry.definition }}</p></header>
<section><h2>Ausführliche Definition</h2><p>{{ entry.long_definition }}</p></section><section><h2>Rechnerische oder analytische Einordnung</h2><div class="lab-formula-card"><code>{{ entry.formula }}</code></div><p>{{ entry.relevance }}</p></section>
<section><h2>Prüffragen für die Praxis</h2><ul>{% for q in entry.questions %}<li>{{ q }}</li>{% endfor %}</ul></section>
<section><h2>{{ entry.case.heading }}</h2><div class="case-study"><div><h3>Ausgangsdaten</h3><ul>{% for item in entry.case.facts %}<li>{{ item }}</li>{% endfor %}</ul></div><div><h3>Berechnung</h3><p>{{ entry.case.calculation }}</p></div><div><h3>Einordnung</h3><p>{{ entry.case.interpretation }}</p></div></div></section>
<section><h2>Typische Fehler</h2><ul>{% for p in entry.pitfalls %}<li>{{ p }}</li>{% endfor %}</ul></section>
<div class="article-actions"><a class="lab-btn lab-btn-gold" href="/investment-lab.html">Im Investment Lab weiterarbeiten</a><a class="lab-btn lab-btn-ghost" href="/ankaufsberatung.html">Ankaufsberatung</a></div></article></main>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"DefinedTerm","name":{{ entry.term | json }},"description":{{ entry.definition | json }},"url":"https://www.fg-realestate.de{{ entry.url }}"}</script>
