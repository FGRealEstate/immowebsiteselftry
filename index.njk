<section id="kontakt" class="container mx-auto px-4 py-16">
    <div class="bg-white rounded-2xl shadow-2xl border-t-4 border-accent overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2">

            <div class="p-8 md:p-12 bg-primary text-white relative overflow-hidden">
                <div class="absolute inset-0 opacity-25">
                    <img src="/images/berlinskypng.png" alt="Berlin Immobilienberatung" class="w-full h-full object-cover">
                </div>

                <div class="relative z-10">
                    <p class="text-secondary font-semibold mb-3 uppercase tracking-wide text-sm">
                        Persönliche Immobilienberatung
                    </p>

                    <h2 class="text-3xl md:text-5xl font-extrabold mb-6 leading-tight">
                        Finden Sie die passende Immobilie oder den richtigen Verkaufsweg.
                    </h2>

                    <p class="text-lg md:text-xl text-page-bg mb-8 leading-relaxed">
                        Beantworten Sie wenige Fragen. Ihre Anfrage wird direkt an unser CRM übergeben und persönlich geprüft.
                    </p>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
                        <div class="bg-white/10 rounded-xl p-5 border border-white/10">
                            <i class="fas fa-user-check text-secondary text-2xl mb-3"></i>
                            <h3 class="font-bold mb-1">Persönlich geprüft</h3>
                            <p class="text-sm text-page-bg">Keine Standardantwort, sondern echte Einordnung.</p>
                        </div>

                        <div class="bg-white/10 rounded-xl p-5 border border-white/10">
                            <i class="fas fa-building text-secondary text-2xl mb-3"></i>
                            <h3 class="font-bold mb-1">CRM-gestützt</h3>
                            <p class="text-sm text-page-bg">Ihre Anfrage wird direkt in Propstack verarbeitet.</p>
                        </div>

                        <div class="bg-white/10 rounded-xl p-5 border border-white/10">
                            <i class="fas fa-shield-alt text-secondary text-2xl mb-3"></i>
                            <h3 class="font-bold mb-1">Diskret</h3>
                            <p class="text-sm text-page-bg">Vertraulicher Umgang mit Ihren Daten und Ihrem Anliegen.</p>
                        </div>

                        <div class="bg-white/10 rounded-xl p-5 border border-white/10">
                            <i class="fas fa-phone-alt text-secondary text-2xl mb-3"></i>
                            <h3 class="font-bold mb-1">Direkter Kontakt</h3>
                            <p class="text-sm text-page-bg">Telefonisch oder per E-Mail, so wie Sie es wünschen.</p>
                        </div>
                    </div>

                    <div class="space-y-3 text-page-bg">
                        <p><i class="fas fa-phone-alt text-secondary mr-2"></i><a href="tel:015203083048" class="hover:underline">01520 3083048</a></p>
                        <p><i class="fas fa-envelope text-secondary mr-2"></i><a href="mailto:info@fg-realestate.de" class="hover:underline">info@fg-realestate.de</a></p>
                    </div>
                </div>
            </div>

            <div class="p-8 md:p-12 bg-white">
                <div class="mb-8">
                    <p class="text-secondary font-semibold mb-2 uppercase tracking-wide text-sm">
                        Anfrage starten
                    </p>

                    <h3 id="lead-step-title" class="text-3xl font-bold text-primary mb-3">
                        Wobei dürfen wir Sie unterstützen?
                    </h3>

                    <p id="lead-step-subtitle" class="text-gray-600">
                        Wählen Sie zuerst Ihr Anliegen aus. Danach passen sich die Fragen automatisch an.
                    </p>

                    <div class="mt-6 h-2 bg-gray-100 rounded-full overflow-hidden">
                        <div id="lead-progress" class="h-full bg-secondary rounded-full transition-all duration-500" style="width: 20%;"></div>
                    </div>
                </div>

                <div id="lead-success" class="hidden mb-6 rounded-xl border border-green-300 bg-green-50 p-5 text-green-800">
                    <h4 class="font-bold text-lg mb-1">Ihre Anfrage wurde erfolgreich übermittelt.</h4>
                    <p>Wir haben Ihre Angaben erhalten und melden uns zeitnah persönlich bei Ihnen.</p>
                </div>

                <div id="lead-error" class="hidden mb-6 rounded-xl border border-red-300 bg-red-50 p-5 text-red-800">
                    <h4 class="font-bold text-lg mb-1">Anfrage konnte nicht gesendet werden.</h4>
                    <p>Bitte versuchen Sie es erneut oder kontaktieren Sie uns direkt per Telefon oder E-Mail.</p>
                </div>

                <form id="propstack-lead-form">
                    <input type="hidden" name="source_url" id="lead-source-url">
                    <input type="hidden" name="concern" id="lead-concern">
                    <input type="hidden" name="object_type" id="lead-object-type">
                    <input type="hidden" name="location" id="lead-location">
                    <input type="hidden" name="budget" id="lead-budget">
                    <input type="hidden" name="timeframe" id="lead-timeframe">
                    <input type="hidden" name="contact_preference" id="lead-contact-preference">

                    <div class="lead-step" data-step="1">
                        <div class="grid grid-cols-1 gap-4">
                            <button type="button" class="lead-choice" data-field="concern" data-value="Immobilie kaufen">
                                <span><i class="fas fa-key text-secondary mr-3"></i>Ich möchte kaufen</span>
                                <i class="fas fa-chevron-right"></i>
                            </button>

                            <button type="button" class="lead-choice" data-field="concern" data-value="Immobilie verkaufen">
                                <span><i class="fas fa-home text-secondary mr-3"></i>Ich möchte verkaufen</span>
                                <i class="fas fa-chevron-right"></i>
                            </button>

                            <button type="button" class="lead-choice" data-field="concern" data-value="Immobilie vermieten">
                                <span><i class="fas fa-building text-secondary mr-3"></i>Ich möchte vermieten</span>
                                <i class="fas fa-chevron-right"></i>
                            </button>

                            <button type="button" class="lead-choice" data-field="concern" data-value="Finanzierung">
                                <span><i class="fas fa-euro-sign text-secondary mr-3"></i>Ich brauche eine Finanzierung</span>
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>
                    </div>

                    <div class="lead-step hidden" data-step="2">
                        <div id="dynamic-question-area" class="grid grid-cols-1 gap-4"></div>
                    </div>

                    <div class="lead-step hidden" data-step="3">
                        <label class="block text-sm font-bold text-primary mb-2">Ort / Suchgebiet *</label>
                        <input type="text" id="visible-location" required placeholder="z. B. Berlin, Potsdam, Dresden" class="w-full p-4 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">

                        <label class="block text-sm font-bold text-primary mb-2 mt-5">Budget / Preisrahmen</label>
                        <input type="text" id="visible-budget" placeholder="z. B. bis 500.000 €" class="w-full p-4 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">

                        <label class="block text-sm font-bold text-primary mb-2 mt-5">Zeitrahmen</label>
                        <select id="visible-timeframe" class="w-full p-4 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                            <option value="">Keine Angabe</option>
                            <option value="Sofort">Sofort</option>
                            <option value="1-3 Monate">1-3 Monate</option>
                            <option value="3-6 Monate">3-6 Monate</option>
                            <option value="6-12 Monate">6-12 Monate</option>
                            <option value="Langfristig">Langfristig</option>
                        </select>
                    </div>

                    <div class="lead-step hidden" data-step="4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-primary mb-2">Vorname *</label>
                                <input type="text" name="first_name" required placeholder="Ihr Vorname" class="w-full p-4 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-primary mb-2">Nachname *</label>
                                <input type="text" name="last_name" required placeholder="Ihr Nachname" class="w-full p-4 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-5">
                            <div>
                                <label class="block text-sm font-bold text-primary mb-2">E-Mail-Adresse *</label>
                                <input type="email" name="email" required placeholder="name@email.de" class="w-full p-4 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-primary mb-2">Telefonnummer</label>
                                <input type="tel" name="phone" placeholder="Ihre Telefonnummer" class="w-full p-4 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                            </div>
                        </div>

                        <label class="block text-sm font-bold text-primary mb-2 mt-5">Bevorzugte Kontaktaufnahme</label>
                        <select id="visible-contact-preference" class="w-full p-4 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                            <option value="E-Mail">Per E-Mail</option>
                            <option value="Telefon">Telefonisch</option>
                            <option value="WhatsApp">Per WhatsApp</option>
                        </select>
                    </div>

                    <div class="lead-step hidden" data-step="5">
                        <label class="block text-sm font-bold text-primary mb-2">Ihre Nachricht</label>
                        <textarea name="message" rows="5" placeholder="Beschreiben Sie kurz Ihr Anliegen..." class="w-full p-4 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary"></textarea>

                        <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 mt-5">
                            <label class="flex items-start gap-3 text-sm text-gray-700">
                                <input type="checkbox" name="privacy_consent" value="true" required class="mt-1 h-4 w-4 text-accent border-gray-300 rounded focus:ring-accent">
                                <span>
                                    Ich habe die
                                    <a href="/datenschutz.html" target="_blank" class="text-primary font-bold hover:underline">Datenschutzerklärung</a>
                                    gelesen und stimme zu, dass meine Angaben zur Bearbeitung meiner Anfrage verarbeitet und an Fischer & Geserich Real Estate übermittelt werden. *
                                </span>
                            </label>
                        </div>
                    </div>

                    <div class="flex justify-between items-center gap-4 mt-8">
                        <button type="button" id="lead-back" class="hidden px-6 py-3 rounded-lg border border-gray-300 text-primary font-bold hover:bg-gray-50">
                            Zurück
                        </button>

                        <button type="button" id="lead-next" class="btn-85 ml-auto px-8 py-3 rounded-lg text-primary font-bold">
                            Weiter
                        </button>

                        <button type="submit" id="lead-submit-button" class="hidden btn-85 ml-auto px-8 py-3 rounded-lg text-primary font-bold">
