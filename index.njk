        </div>
    </div>
</section>

<style>
.lead-choice {
    width: 100%;
    padding: 1rem 1.25rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.9rem;
    background: #ffffff;
    color: #080832;
    font-weight: 700;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: 0.25s ease;
    text-align: left;
}

.lead-choice:hover,
.lead-choice.is-selected {
    border-color: #d4af37;
    box-shadow: 0 14px 30px rgba(0,0,0,0.10);
    transform: translateY(-2px);
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("propstack-lead-form");
    const steps = Array.from(document.querySelectorAll(".lead-step"));
    const nextButton = document.getElementById("lead-next");
    const backButton = document.getElementById("lead-back");
    const submitButton = document.getElementById("lead-submit-button");
    const progress = document.getElementById("lead-progress");
    const title = document.getElementById("lead-step-title");
    const subtitle = document.getElementById("lead-step-subtitle");
    const dynamicArea = document.getElementById("dynamic-question-area");
    const successBox = document.getElementById("lead-success");
    const errorBox = document.getElementById("lead-error");

    if (!form) return;

    let currentStep = 1;
    const state = {
        concern: "",
        object_type: "",
        location: "",
        budget: "",
        timeframe: "",
        contact_preference: "E-Mail"
    };

    const stepText = {
        1: ["Wobei dürfen wir Sie unterstützen?", "Wählen Sie zuerst Ihr Anliegen aus."],
        2: ["Welche Immobilie betrifft Ihr Anliegen?", "Die nächsten Fragen passen sich an Ihre Auswahl an."],
        3: ["Wo und in welchem Rahmen?", "Geben Sie Suchgebiet, Budget oder Zeitrahmen an."],
        4: ["Wie erreichen wir Sie?", "Damit wir Ihre Anfrage persönlich zuordnen können."],
        5: ["Fast geschafft.", "Prüfen Sie Ihre Angaben und senden Sie die Anfrage ab."]
    };

    const dynamicOptions = {
        "Immobilie kaufen": [
            ["Eigentumswohnung", "fas fa-city"],
            ["Haus", "fas fa-home"],
            ["Mehrfamilienhaus", "fas fa-building"],
            ["Grundstück", "fas fa-map"],
            ["Kapitalanlage", "fas fa-chart-line"]
        ],
        "Immobilie verkaufen": [
            ["Eigentumswohnung verkaufen", "fas fa-city"],
            ["Haus verkaufen", "fas fa-home"],
            ["Mehrfamilienhaus verkaufen", "fas fa-building"],
            ["Grundstück verkaufen", "fas fa-map"],
            ["Diskret / Off-Market verkaufen", "fas fa-user-secret"]
        ],
        "Immobilie vermieten": [
            ["Wohnung vermieten", "fas fa-key"],
            ["Haus vermieten", "fas fa-home"],
            ["Gewerbe vermieten", "fas fa-store"],
            ["Verwaltung anfragen", "fas fa-clipboard-list"]
        ],
        "Finanzierung": [
            ["Kauf finanzieren", "fas fa-euro-sign"],
            ["Anschlussfinanzierung", "fas fa-file-invoice"],
            ["Kapitalanlage finanzieren", "fas fa-chart-line"],
            ["Beratung gewünscht", "fas fa-comments"]
        ]
    };

    function showStep(step) {
        currentStep = step;

        steps.forEach(function (item) {
            item.classList.toggle("hidden", Number(item.dataset.step) !== currentStep);
        });

        title.textContent = stepText[currentStep][0];
        subtitle.textContent = stepText[currentStep][1];
        progress.style.width = `${currentStep * 20}%`;

        backButton.classList.toggle("hidden", currentStep === 1);
        nextButton.classList.toggle("hidden", currentStep === 5);
        submitButton.classList.toggle("hidden", currentStep !== 5);

        if (currentStep === 2) renderDynamicOptions();
    }

    function renderDynamicOptions() {
        dynamicArea.innerHTML = "";

        const options = dynamicOptions[state.concern] || [];

        options.forEach(function ([label, icon]) {
            const button = document.createElement("button");
            button.type = "button";
            button.className = "lead-choice";
            button.innerHTML = `<span><i class="${icon} text-secondary mr-3"></i>${label}</span><i class="fas fa-chevron-right"></i>`;

            button.addEventListener("click", function () {
                state.object_type = label;
                document.getElementById("lead-object-type").value = label;
                showStep(3);
            });

            dynamicArea.appendChild(button);
        });
    }

    document.querySelectorAll(".lead-choice[data-field='concern']").forEach(function (button) {
        button.addEventListener("click", function () {
            state.concern = button.dataset.value;
            document.getElementById("lead-concern").value = state.concern;
            showStep(2);
        });
    });

    nextButton.addEventListener("click", function () {
        if (currentStep === 1 && !state.concern) return;

        if (currentStep === 3) {
            state.location = document.getElementById("visible-location").value;
            state.budget = document.getElementById("visible-budget").value;
            state.timeframe = document.getElementById("visible-timeframe").value;

            document.getElementById("lead-location").value = state.location;
            document.getElementById("lead-budget").value = state.budget;
            document.getElementById("lead-timeframe").value = state.timeframe;
        }

        if (currentStep === 4) {
            state.contact_preference = document.getElementById("visible-contact-preference").value;
            document.getElementById("lead-contact-preference").value = state.contact_preference;
        }

        if (currentStep < 5) showStep(currentStep + 1);
    });

    backButton.addEventListener("click", function () {
        if (currentStep > 1) showStep(currentStep - 1);
    });

    form.addEventListener("submit", async function (event) {
        event.preventDefault();

        successBox.classList.add("hidden");
        errorBox.classList.add("hidden");

        submitButton.disabled = true;
        submitButton.textContent = "Wird übermittelt...";

        const formData = new FormData(form);

        const payload = {
            first_name: formData.get("first_name"),
            last_name: formData.get("last_name"),
            email: formData.get("email"),
            phone: formData.get("phone"),
            concern: document.getElementById("lead-concern").value,
            object_type: document.getElementById("lead-object-type").value,
            location: document.getElementById("lead-location").value,
            budget: document.getElementById("lead-budget").value,
            timeframe: document.getElementById("lead-timeframe").value,
            contact_preference: document.getElementById("lead-contact-preference").value,
            message: formData.get("message"),
            privacy_consent: formData.get("privacy_consent") === "true",
            source_url: window.location.href
        };

        try {
            const response = await fetch("/.netlify/functions/propstack-lead", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });

            const result = await response.json();

            if (!response.ok || !result.success) throw new Error(result.error || "Fehler");

            form.reset();
            successBox.classList.remove("hidden");
            showStep(1);

        } catch (error) {
            errorBox.classList.remove("hidden");
        } finally {
            submitButton.disabled = false;
            submitButton.textContent = "Anfrage absenden";
        }
    });

    showStep(1);
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("propstack-lead-form");
    const successBox = document.getElementById("lead-success");
    const errorBox = document.getElementById("lead-error");
    const submitButton = document.getElementById("lead-submit-button");
    const sourceUrl = document.getElementById("lead-source-url");

    if (!form) return;

    if (sourceUrl) {
        sourceUrl.value = window.location.href;
    }

    form.addEventListener("submit", async function (event) {
        event.preventDefault();

        successBox.classList.add("hidden");
        errorBox.classList.add("hidden");

        submitButton.disabled = true;
        submitButton.textContent = "Anfrage wird übermittelt...";

        const formData = new FormData(form);

        const payload = {
            first_name: formData.get("first_name"),
            last_name: formData.get("last_name"),
            email: formData.get("email"),
            phone: formData.get("phone"),
            concern: formData.get("concern"),
            object_type: formData.get("object_type"),
            location: formData.get("location"),
            budget: formData.get("budget"),
            timeframe: formData.get("timeframe"),
            contact_preference: formData.get("contact_preference"),
            message: formData.get("message"),
            privacy_consent: formData.get("privacy_consent") === "true",
            source_url: window.location.href
        };

        try {
            const response = await fetch("/.netlify/functions/propstack-lead", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            });

            const result = await response.json();

            if (!response.ok || !result.success) {
                throw new Error(result.error || "Unbekannter Fehler");
            }

            form.reset();
            successBox.classList.remove("hidden");
            successBox.scrollIntoView({ behavior: "smooth", block: "center" });

        } catch (error) {
            console.error("Lead Fehler:", error);
            errorBox.classList.remove("hidden");
            errorBox.scrollIntoView({ behavior: "smooth", block: "center" });

        } finally {
            submitButton.disabled = false;
            submitButton.textContent = "Anfrage absenden";
        }
    });
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const cards = Array.from(document.querySelectorAll(".home-property-card"));
    const prevDesktop = document.getElementById("home-slider-prev");
    const nextDesktop = document.getElementById("home-slider-next");
    const prevMobile = document.getElementById("home-slider-prev-mobile");
    const nextMobile = document.getElementById("home-slider-next-mobile");

    if (!cards.length) return;

    const visibleCount = 3;
    const maxCards = Math.min(cards.length, 9);
    let startIndex = 0;

    function updateCards() {
        cards.forEach(function (card, index) {
            const isVisible =
                index >= startIndex &&
                index < startIndex + visibleCount;

            if (isVisible) {
                card.classList.remove("hidden");
            } else {
                card.classList.add("hidden");
            }
        });
    }

    function next() {
        if (maxCards <= visibleCount) return;

        startIndex = startIndex + visibleCount;

        if (startIndex >= maxCards) {
            startIndex = 0;
        }

        updateCards();
    }

    function prev() {
        if (maxCards <= visibleCount) return;

        startIndex = startIndex - visibleCount;

        if (startIndex < 0) {
            startIndex = Math.max(0, maxCards - visibleCount);
        }

        updateCards();
    }

    if (nextDesktop) nextDesktop.addEventListener("click", next);
    if (prevDesktop) prevDesktop.addEventListener("click", prev);
    if (nextMobile) nextMobile.addEventListener("click", next);
    if (prevMobile) prevMobile.addEventListener("click", prev);

    updateCards();
});
</script>
