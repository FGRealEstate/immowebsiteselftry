<section id="kontakt" class="container mx-auto px-4 py-16">
    <div class="bg-white rounded-2xl shadow-2xl border-t-4 border-accent overflow-hidden">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">

            <div class="p-8 md:p-12 bg-primary text-white relative overflow-hidden">
                <div class="absolute inset-0 opacity-20">
                    <img src="/images/berlinskypng.png" alt="Berlin Immobilienberatung" class="w-full h-full object-cover">
                </div>

                <div class="relative z-10">
                    <p class="text-secondary font-semibold mb-3 uppercase tracking-wide text-sm">
                        Persönliche Immobilienberatung
                    </p>

                    <h2 class="text-3xl md:text-5xl font-extrabold mb-6 leading-tight">
                        Finden Sie die passende Immobilie oder den richtigen Verkaufsweg.
                    </h2>

                    <p class="text-lg md:text-xl text-page-bg mb-8 leading-relaxed">
                        Ob Kauf, Verkauf, Finanzierung oder Vermietung – wir prüfen Ihr Anliegen persönlich und melden uns mit einer passenden Einschätzung zurück.
                    </p>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
                        <div class="bg-white/10 rounded-xl p-5 border border-white/10">
                            <i class="fas fa-user-check text-secondary text-2xl mb-3"></i>
                            <h3 class="font-bold mb-1">Persönlich geprüft</h3>
                            <p class="text-sm text-page-bg">Keine Standardantwort, sondern echte Einordnung.</p>
                        </div>

                        <div class="bg-white/10 rounded-xl p-5 border border-white/10">
                            <i class="fas fa-building text-secondary text-2xl mb-3"></i>
                            <h3 class="font-bold mb-1">CRM-gestützt</h3>
                            <p class="text-sm text-page-bg">Ihre Anfrage wird direkt in Propstack verarbeitet.</p>
                        </div>

                        <div class="bg-white/10 rounded-xl p-5 border border-white/10">
                            <i class="fas fa-shield-alt text-secondary text-2xl mb-3"></i>
                            <h3 class="font-bold mb-1">Diskret</h3>
                            <p class="text-sm text-page-bg">Vertraulicher Umgang mit Ihren Daten und Ihrem Anliegen.</p>
                        </div>

                        <div class="bg-white/10 rounded-xl p-5 border border-white/10">
                            <i class="fas fa-phone-alt text-secondary text-2xl mb-3"></i>
                            <h3 class="font-bold mb-1">Direkter Kontakt</h3>
                            <p class="text-sm text-page-bg">Telefonisch oder per E-Mail, so wie Sie es wünschen.</p>
                        </div>
                    </div>

                    <div class="space-y-3 text-page-bg">
                        <p>
                            <i class="fas fa-phone-alt text-secondary mr-2"></i>
                            <a href="tel:015203083048" class="hover:underline">01520 3083048</a>
                        </p>
                        <p>
                            <i class="fas fa-envelope text-secondary mr-2"></i>
                            <a href="mailto:info@fg-realestate.de" class="hover:underline">info@fg-realestate.de</a>
                        </p>
                    </div>
                </div>
            </div>

            <div class="p-8 md:p-12 bg-white">
                <p class="text-secondary font-semibold mb-2 uppercase tracking-wide text-sm">
                    Anfrage starten
                </p>

                <h3 class="text-3xl font-bold text-primary mb-3">
                    Wobei dürfen wir Sie unterstützen?
                </h3>

                <p class="text-gray-600 mb-8">
                    Füllen Sie das Formular aus. Ihre Anfrage wird direkt an unser CRM übergeben.
                </p>

                <div id="lead-success" class="hidden mb-6 rounded-xl border border-green-300 bg-green-50 p-5 text-green-800">
                    <h4 class="font-bold text-lg mb-1">Ihre Anfrage wurde erfolgreich übermittelt.</h4>
                    <p>Wir haben Ihre Angaben erhalten und melden uns zeitnah persönlich bei Ihnen.</p>
                </div>

                <div id="lead-error" class="hidden mb-6 rounded-xl border border-red-300 bg-red-50 p-5 text-red-800">
                    <h4 class="font-bold text-lg mb-1">Anfrage konnte nicht gesendet werden.</h4>
                    <p>Bitte versuchen Sie es erneut oder kontaktieren Sie uns direkt per Telefon oder E-Mail.</p>
                </div>

                <form id="propstack-lead-form" class="space-y-5">

                    <input type="hidden" name="source_url" id="lead-source-url">

                    <div>
                        <label class="block text-sm font-bold text-primary mb-2">Ihr Anliegen *</label>
                        <select name="concern" required class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                            <option value="" disabled selected>Bitte auswählen</option>
                            <option value="Immobilie kaufen">Immobilie kaufen</option>
                            <option value="Immobilie verkaufen">Immobilie verkaufen</option>
                            <option value="Immobilie vermieten">Immobilie vermieten</option>
                            <option value="Finanzierung">Finanzierung</option>
                            <option value="Ankaufsberatung">Ankaufsberatung</option>
                            <option value="Allgemeine Beratung">Allgemeine Beratung</option>
                        </select>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-primary mb-2">Vorname *</label>
                            <input type="text" name="first_name" required placeholder="Ihr Vorname" class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-primary mb-2">Nachname *</label>
                            <input type="text" name="last_name" required placeholder="Ihr Nachname" class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-primary mb-2">E-Mail-Adresse *</label>
                            <input type="email" name="email" required placeholder="name@email.de" class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-primary mb-2">Telefonnummer</label>
                            <input type="tel" name="phone" placeholder="Ihre Telefonnummer" class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-primary mb-2">Objektart</label>
                            <select name="object_type" class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                                <option value="">Keine Angabe</option>
                                <option value="Eigentumswohnung">Eigentumswohnung</option>
                                <option value="Haus">Haus</option>
                                <option value="Mehrfamilienhaus">Mehrfamilienhaus</option>
                                <option value="Grundstück">Grundstück</option>
                                <option value="Gewerbe">Gewerbe</option>
                                <option value="Kapitalanlage">Kapitalanlage</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-primary mb-2">Ort / Suchgebiet</label>
                            <input type="text" name="location" placeholder="z. B. Berlin, Potsdam, Dresden" class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-primary mb-2">Budget / Preisrahmen</label>
                            <input type="text" name="budget" placeholder="z. B. bis 500.000 €" class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-primary mb-2">Zeitrahmen</label>
                            <select name="timeframe" class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                                <option value="">Keine Angabe</option>
                                <option value="Sofort">Sofort</option>
                                <option value="1-3 Monate">1-3 Monate</option>
                                <option value="3-6 Monate">3-6 Monate</option>
                                <option value="6-12 Monate">6-12 Monate</option>
                                <option value="Langfristig">Langfristig</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-primary mb-2">Bevorzugte Kontaktaufnahme</label>
                        <select name="contact_preference" class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary">
                            <option value="E-Mail">Per E-Mail</option>
                            <option value="Telefon">Telefonisch</option>
                            <option value="WhatsApp">Per WhatsApp</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-primary mb-2">Ihre Nachricht</label>
                        <textarea name="message" rows="4" placeholder="Beschreiben Sie kurz Ihr Anliegen..." class="w-full p-3 border border-gray-300 rounded-lg focus:border-primary focus:ring-primary"></textarea>
                    </div>

                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
                        <label class="flex items-start gap-3 text-sm text-gray-700">
                            <input type="checkbox" name="privacy_consent" value="true" required class="mt-1 h-4 w-4 text-accent border-gray-300 rounded focus:ring-accent">
                            <span>
                                Ich habe die
                                <a href="/datenschutz.html" target="_blank" class="text-primary font-bold hover:underline">Datenschutzerklärung</a>
                                gelesen und stimme zu, dass meine Angaben zur Bearbeitung meiner Anfrage verarbeitet und an Fischer & Geserich Real Estate übermittelt werden. *
                            </span>
                        </label>
                    </div>

                    <button id="lead-submit-button" type="submit" class="btn-85 w-full text-primary font-bold py-4 rounded-lg shadow-lg transition duration-300">
                        Anfrage absenden
                    </button>

                    <p class="text-xs text-gray-500 text-center">
                        Ihre Angaben werden ausschließlich zur Bearbeitung Ihrer Anfrage genutzt.
                    </p>

                </form>
            </div>

        </div>
    </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("propstack-lead-form");
    const successBox = document.getElementById("lead-success");
    const errorBox = document.getElementById("lead-error");
    const submitButton = document.getElementById("lead-submit-button");
    const sourceUrl = document.getElementById("lead-source-url");

    if (!form) return;

    if (sourceUrl) {
        sourceUrl.value = window.location.href;
    }

    form.addEventListener("submit", async function (event) {
        event.preventDefault();

        successBox.classList.add("hidden");
        errorBox.classList.add("hidden");

        submitButton.disabled = true;
        submitButton.textContent = "Anfrage wird übermittelt...";

        const formData = new FormData(form);

        const payload = {
            first_name: formData.get("first_name"),
            last_name: formData.get("last_name"),
            email: formData.get("email"),
            phone: formData.get("phone"),
            concern: formData.get("concern"),
            object_type: formData.get("object_type"),
            location: formData.get("location"),
            budget: formData.get("budget"),
            timeframe: formData.get("timeframe"),
            contact_preference: formData.get("contact_preference"),
            message: formData.get("message"),
            privacy_consent: formData.get("privacy_consent") === "true",
            source_url: window.location.href
        };

        try {
            const response = await fetch("/.netlify/functions/propstack-lead", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            });

            const result = await response.json();

            if (!response.ok || !result.success) {
                throw new Error(result.error || "Unbekannter Fehler");
            }

            form.reset();
            successBox.classList.remove("hidden");
            successBox.scrollIntoView({ behavior: "smooth", block: "center" });

        } catch (error) {
            console.error("Lead Fehler:", error);
            errorBox.classList.remove("hidden");
            errorBox.scrollIntoView({ behavior: "smooth", block: "center" });

        } finally {
            submitButton.disabled = false;
            submitButton.textContent = "Anfrage absenden";
        }
    });
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const cards = Array.from(document.querySelectorAll(".home-property-card"));
    const prevDesktop = document.getElementById("home-slider-prev");
    const nextDesktop = document.getElementById("home-slider-next");
    const prevMobile = document.getElementById("home-slider-prev-mobile");
    const nextMobile = document.getElementById("home-slider-next-mobile");

    if (!cards.length) return;

    const visibleCount = 3;
    const maxCards = Math.min(cards.length, 9);
    let startIndex = 0;

    function updateCards() {
        cards.forEach(function (card, index) {
            const isVisible =
                index >= startIndex &&
                index < startIndex + visibleCount;

            if (isVisible) {
                card.classList.remove("hidden");
            } else {
                card.classList.add("hidden");
            }
        });
    }

    function next() {
        if (maxCards <= visibleCount) return;

        startIndex = startIndex + visibleCount;

        if (startIndex >= maxCards) {
            startIndex = 0;
        }

        updateCards();
    }

    function prev() {
        if (maxCards <= visibleCount) return;

        startIndex = startIndex - visibleCount;

        if (startIndex < 0) {
            startIndex = Math.max(0, maxCards - visibleCount);
        }

        updateCards();
    }

    if (nextDesktop) nextDesktop.addEventListener("click", next);
    if (prevDesktop) prevDesktop.addEventListener("click", prev);
    if (nextMobile) nextMobile.addEventListener("click", next);
    if (prevMobile) prevMobile.addEventListener("click", prev);

    updateCards();
});
</script>
