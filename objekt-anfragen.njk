<section class="bg-primary text-white py-16 md:py-24">
    <div class="container mx-auto px-4 text-center">
        <p class="text-secondary mb-3 font-semibold uppercase tracking-wide">
            Immobilienanfrage
        </p>

        <h1 class="text-4xl md:text-5xl font-extrabold mb-4 leading-tight">
            Objekt unverbindlich anfragen
        </h1>

        <p class="text-lg md:text-xl font-light text-secondary max-w-3xl mx-auto">
            Teilen Sie uns kurz Ihre Kontaktdaten mit. Wir melden uns persönlich bei Ihnen zurück.
        </p>
    </div>
</section>

<section class="container mx-auto px-4 py-16">

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">

        <div class="lg:col-span-2">

            <div class="bg-white rounded-xl shadow-2xl p-8 md:p-10 border-t-4 border-accent">

                <div id="success-message" class="hidden mb-8 bg-green-50 border border-green-200 rounded-lg p-6">
                    <h2 class="text-2xl font-bold text-primary mb-2">
                        Anfrage erfolgreich versendet
                    </h2>
                    <p class="text-gray-700">
                        Vielen Dank. Ihre Objektanfrage wurde erfolgreich übermittelt. Wir melden uns schnellstmöglich persönlich bei Ihnen.
                    </p>
                </div>

                <div id="error-message" class="hidden mb-8 bg-red-50 border border-red-200 rounded-lg p-6">
                    <h2 class="text-2xl font-bold text-primary mb-2">
                        Anfrage konnte nicht gesendet werden
                    </h2>
                    <p class="text-gray-700">
                        Bitte versuchen Sie es erneut oder kontaktieren Sie uns direkt per Telefon oder E-Mail.
                    </p>
                </div>

                <form id="object-request-form" class="space-y-6">

                    <input type="hidden" id="object-id" name="object_id">
                    <input type="hidden" id="object-title" name="object_title">
                    <input type="hidden" id="source-url" name="source_url">

                    <div>
                        <label class="block text-primary font-semibold mb-2">
                            Angefragtes Objekt
                        </label>

                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                            <p id="object-title-preview" class="font-bold text-primary">
                                Objekt wird geladen …
                            </p>
                            <p class="text-sm text-gray-500 mt-1">
                                Ihre Anfrage wird diesem Objekt zugeordnet.
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label for="first-name" class="block text-primary font-semibold mb-2">
                                Vorname *
                            </label>
                            <input
                                type="text"
                                id="first-name"
                                name="first_name"
                                required
                                autocomplete="given-name"
                                class="w-full p-3 border border-gray-300 rounded focus:border-primary focus:ring-primary"
                            >
                        </div>

                        <div>
                            <label for="last-name" class="block text-primary font-semibold mb-2">
                                Nachname *
                            </label>
                            <input
                                type="text"
                                id="last-name"
                                name="last_name"
                                required
                                autocomplete="family-name"
                                class="w-full p-3 border border-gray-300 rounded focus:border-primary focus:ring-primary"
                            >
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label for="email" class="block text-primary font-semibold mb-2">
                                E-Mail-Adresse *
                            </label>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                                autocomplete="email"
                                class="w-full p-3 border border-gray-300 rounded focus:border-primary focus:ring-primary"
                            >
                        </div>

                        <div>
                            <label for="phone" class="block text-primary font-semibold mb-2">
                                Telefonnummer
                            </label>
                            <input
                                type="tel"
                                id="phone"
                                name="phone"
                                autocomplete="tel"
                                class="w-full p-3 border border-gray-300 rounded focus:border-primary focus:ring-primary"
                            >
                        </div>
                    </div>

                    <div>
                        <label for="contact-preference" class="block text-primary font-semibold mb-2">
                            Bevorzugte Kontaktaufnahme
                        </label>
                        <select
                            id="contact-preference"
                            name="contact_preference"
                            class="w-full p-3 border border-gray-300 rounded focus:border-primary focus:ring-primary text-gray-700"
                        >
                            <option value="E-Mail">Per E-Mail</option>
                            <option value="Telefon">Per Telefon</option>
                            <option value="WhatsApp">Per WhatsApp</option>
                            <option value="Egal">Egal</option>
                        </select>
                    </div>

                    <div>
                        <label for="message" class="block text-primary font-semibold mb-2">
                            Ihre Nachricht
                        </label>
                        <textarea
                            id="message"
                            name="message"
                            rows="5"
                            class="w-full p-3 border border-gray-300 rounded focus:border-primary focus:ring-primary"
                            placeholder="Guten Tag, ich interessiere mich für dieses Objekt und bitte um weitere Informationen."
                        ></textarea>
                    </div>

                    <div class="bg-gray-50 rounded-lg p-5 border border-gray-200 space-y-4">

                        <div class="flex items-start">
                            <input
                                type="checkbox"
                                id="privacy"
                                name="privacy"
                                value="zugestimmt"
                                required
                                class="mt-1 mr-3 h-4 w-4 text-accent border-gray-300 rounded focus:ring-accent"
                            >

                            <label for="privacy" class="text-sm text-gray-700 leading-relaxed">
                                Ich habe die
                                <a href="/datenschutz.html" target="_blank" class="text-primary font-semibold hover:underline">
                                    Datenschutzerklärung
                                </a>
                                gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung meiner Objektanfrage zu. *
                            </label>
                        </div>

                        <p class="text-xs text-gray-500 leading-relaxed">
                            Hinweise zu Widerruf, Verbraucherinformationen und weiteren Unterlagen erhalten Sie im weiteren Anfrageprozess.
                        </p>

                    </div>

                    <button
                        type="submit"
                        id="submit-button"
                        class="btn-85 w-full text-primary font-bold py-4 rounded-lg shadow-md transition duration-300"
                    >
                        Objekt jetzt anfragen
                    </button>

                </form>

            </div>
        </div>

        <aside class="lg:col-span-1">
            <div class="bg-white rounded-xl shadow-xl p-8 sticky top-8 border-t-4 border-accent">

                <h2 class="text-2xl font-bold text-primary mb-6">
                    Ihre Vorteile
                </h2>

                <div class="space-y-5 text-gray-700">

                    <div class="flex gap-3">
                        <i class="fas fa-check-circle text-accent mt-1"></i>
                        <p>
                            Persönliche Rückmeldung durch unser Team.
                        </p>
                    </div>

                    <div class="flex gap-3">
                        <i class="fas fa-check-circle text-accent mt-1"></i>
                        <p>
                            Diskrete und vertrauliche Bearbeitung Ihrer Anfrage.
                        </p>
                    </div>

                    <div class="flex gap-3">
                        <i class="fas fa-check-circle text-accent mt-1"></i>
                        <p>
                            Auf Wunsch erhalten Sie weitere Objektinformationen und Besichtigungsmöglichkeiten.
                        </p>
                    </div>

                    <div class="flex gap-3">
                        <i class="fas fa-check-circle text-accent mt-1"></i>
                        <p>
                            Ihre Anfrage wird direkt dem passenden Objekt zugeordnet.
                        </p>
                    </div>

                </div>

                <div class="mt-8 pt-6 border-t border-gray-100">
                    <p class="text-sm text-gray-500 mb-2">
                        Direktkontakt
                    </p>

                    <p class="mb-2">
                        <i class="fas fa-phone-alt text-accent mr-2"></i>
                        <a href="tel:015203083048" class="text-primary font-semibold hover:underline">
                            01520 3083048
                        </a>
                    </p>

                    <p>
                        <i class="fas fa-envelope text-accent mr-2"></i>
                        <a href="mailto:info@fg-realestate.de" class="text-primary font-semibold hover:underline">
                            info@fg-realestate.de
                        </a>
                    </p>
                </div>

                <a href="/angebote.html" class="block text-center text-primary mt-8 font-semibold hover:underline">
                    Zurück zu den Angeboten
                </a>

            </div>
        </aside>

    </div>

</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("object-request-form");
    const submitButton = document.getElementById("submit-button");
    const successMessage = document.getElementById("success-message");
    const errorMessage = document.getElementById("error-message");

    const objectIdInput = document.getElementById("object-id");
    const objectTitleInput = document.getElementById("object-title");
    const sourceUrlInput = document.getElementById("source-url");
    const objectTitlePreview = document.getElementById("object-title-preview");

    const params = new URLSearchParams(window.location.search);

    const objectId = params.get("object_id") || "";
    const objectTitle = params.get("object") || "Angefragtes Objekt";

    objectIdInput.value = objectId;
    objectTitleInput.value = objectTitle;
    sourceUrlInput.value = window.location.href;

    objectTitlePreview.textContent = objectTitle;

    form.addEventListener("submit", async function (event) {
        event.preventDefault();

        successMessage.classList.add("hidden");
        errorMessage.classList.add("hidden");

        submitButton.disabled = true;
        submitButton.textContent = "Anfrage wird gesendet …";
        submitButton.classList.add("opacity-70", "cursor-not-allowed");

        const formData = new FormData(form);

        const payload = {
            object_id: formData.get("object_id"),
            object_title: formData.get("object_title"),
            source_url: formData.get("source_url"),
            first_name: formData.get("first_name"),
            last_name: formData.get("last_name"),
            email: formData.get("email"),
            phone: formData.get("phone"),
            contact_preference: formData.get("contact_preference"),
            message: formData.get("message"),
            privacy: formData.get("privacy")
        };

        try {
            const response = await fetch("/.netlify/functions/propstack-inquiry", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                throw new Error("Request failed");
            }

            form.reset();

            objectIdInput.value = objectId;
            objectTitleInput.value = objectTitle;
            sourceUrlInput.value = window.location.href;
            objectTitlePreview.textContent = objectTitle;

            successMessage.classList.remove("hidden");

            successMessage.scrollIntoView({
                behavior: "smooth",
                block: "center"
            });

        } catch (error) {
            errorMessage.classList.remove("hidden");

            errorMessage.scrollIntoView({
                behavior: "smooth",
                block: "center"
            });

        } finally {
            submitButton.disabled = false;
            submitButton.textContent = "Objekt jetzt anfragen";
            submitButton.classList.remove("opacity-70", "cursor-not-allowed");
        }
    });
});
</script>
