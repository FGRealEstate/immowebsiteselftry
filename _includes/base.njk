<!DOCTYPE html>
<html lang="de">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{{ title }} | Fischer & Geserich Real Estate GmbH</title>

    <!-- F&G Consent Manager: Website bleibt sichtbar; Tracking startet erst nach Einwilligung -->
    <link rel="stylesheet" href="/vendor/cookieconsent/cookieconsent.css">
    <link rel="stylesheet" href="/consent-manager.css">
    <script defer src="/vendor/cookieconsent/cookieconsent.umd.js"></script>
    <script defer src="/consent-manager.js"></script>

    <!-- TAILWIND -->
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary': '#08082F',
                        'secondary': '#91DCFF',
                        'accent': '#D1B464',
                        'page-bg': '#CDD2D4'
                    },
                    fontFamily: {
                        'sans': ['"Times New Roman"', 'Times', 'serif']
                    }
                }
            }
        }
    </script>

    <!-- CSS -->
    <link rel="stylesheet" href="/style.css">

    <!-- FONT AWESOME -->
    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Externe Dienste werden durch consent-manager.js erst nach Einwilligung geladen. -->
    <script>
        window.FG_GOOGLE_MAPS_API_KEY = "";
        window.FG_GTM_ID = "GTM-5DVGRHB2";
    </script>



    <style>
        /*
         * FG Real Estate – heller Premium-Hintergrund mit originalen Kratzerlinien
         * Wichtig:
         * - Nutzt wieder /images/background.svg
         * - Kein dunkler Navy-Body
         * - Keine globalen Textfarben
         * - Keine Änderungen an Karten, Formularen oder Buttons
         */
        .site-background {
            background-image:
                linear-gradient(
                    135deg,
                    rgba(245, 241, 231, 0.78) 0%,
                    rgba(231, 224, 207, 0.70) 42%,
                    rgba(214, 204, 181, 0.62) 100%
                ),
                url('/images/background.svg') !important;
            background-repeat: no-repeat !important;
            background-size: cover !important;
            background-position: center center !important;
            background-attachment: fixed !important;
            background-color: #E8E1D4 !important;
        }
    </style>

</head>

<body class="site-background">


<nav class="fg-sticky-header bg-primary text-white shadow-lg">
    
    <div class="flex justify-between items-center py-4 px-4 sm:px-6 lg:px-8">
        
        <div class="text-2xl font-bold">
            <a href="/index.html" class="flex items-center text-gold-metallic hover:opacity-90 transition">
                                    <img src="/images/fg-logo-gold-transparent.png" alt="Fischer & Geserich Real Estate" class="fg-header-logo" width="54" height="54">
                                <span class="inline-block xl:hidden text-base">
                                    Fischer & Geserich<br>
                                    Real Estate
                                </span>
                                
                                <span class="hidden xl:inline text-xl">
                                    Fischer & Geserich Real Estate
                                </span>
                                            </a>
                                        </div>
                                
                                        <div class="xl:hidden">
                                            <button id="mobile-menu-button" class="text-white focus:outline-none">
                                                <i class="fas fa-bars text-2xl"></i>
                                            </button>
                                        </div>
                                        
                                        <div class="hidden xl:flex space-x-8 items-center">
                                                           
                                            {% set currentUrl = page.url | url %}
                                            {% set activeClass = "text-gold-gradient with-shadow font-bold border-b-2 border-accent pb-1 whitespace-nowrap" %}
                                            {% set defaultClass = "hover:text-accent whitespace-nowrap" %}
                                                        
                                            <a href="/index.html"
                                               class="{% if currentUrl == '/' or currentUrl == '/index.html' %}{{ activeClass }}{% else %}{{ defaultClass }}{% endif %}">Start</a>
                                                        
                                            <a href="/angebote.html"
                                               class="{% if currentUrl == '/angebote.html' %}{{ activeClass }}{% else %}{{ defaultClass }}{% endif %}">Angebote</a>
                                                                        
                                            <a href="/ankaufsberatung.html"
                                               class="{% if currentUrl == '/ankaufsberatung.html' %}{{ activeClass }}{% else %}{{ defaultClass }}{% endif %}">Ankaufsberatung</a>

                                            <a href="/investment-lab.html"
                                               class="{% if currentUrl == '/investment-lab.html' %}{{ activeClass }}{% else %}{{ defaultClass }}{% endif %}">Investment Lab</a>
                                                        
                                            <a href="/finanzierungsberatung.html"
                                               class="{% if currentUrl == '/finanzierungsberatung.html' %}{{ activeClass }}{% else %}{{ defaultClass }}{% endif %}">Finanzierung</a>
                                                                             
                                            <a href="/verkaufen.html"
                                               class="{% if currentUrl == '/verkaufen.html' %}{{ activeClass }}{% else %}{{ defaultClass }}{% endif %}">Verkaufen</a>
                                                                        
                                            {#
                                            <a href="/verwaltung.html"
                                               class="{% if currentUrl == '/verwaltung.html' %}{{ activeClass }}{% else %}{{ defaultClass }}{% endif %}">Verwaltung</a>
                                            #}
                                                                  
                                            <a href="/ueber-uns.html"
                                               class="{% if currentUrl == '/ueber-uns.html' %}{{ activeClass }}{% else %}{{ defaultClass }}{% endif %}">Über uns</a>
                                            
                                            <a href="/index.html#kontakt" class="btn-85 text-base font-bold py-2 px-6 whitespace-nowrap">Kontakt</a>
                                        </div>
                                    </div>
                                    
                                    <div id="mobile-menu" class="hidden xl:hidden pb-4 shadow-xl bg-primary px-4 sm:px-6 lg:px-8">
                                        <div class="flex flex-col space-y-2">
                                            {% set mobileActiveClass = "block px-3 py-2 bg-accent text-primary rounded font-semibold" %}
                                            {% set mobileDefaultClass = "block px-3 py-2 hover:bg-primary/90 rounded" %}
                                    
                                            <a href="/index.html" class="{% if currentUrl == '/' or currentUrl == '/index.html' %}{{ mobileActiveClass }}{% else %}{{ mobileDefaultClass }}{% endif %}">Start</a>
                                            <a href="/angebote.html" class="{% if currentUrl == '/angebote.html' %}{{ mobileActiveClass }}{% else %}{{ mobileDefaultClass }}{% endif %}">Angebote</a>
                                            <a href="/ankaufsberatung.html" class="{% if currentUrl == '/ankaufsberatung.html' %}{{ mobileActiveClass }}{% else %}{{ mobileDefaultClass }}{% endif %}">Ankaufsberatung</a>
                                            <a href="/investment-lab.html" class="{% if currentUrl == '/investment-lab.html' %}{{ mobileActiveClass }}{% else %}{{ mobileDefaultClass }}{% endif %}">Investment Lab</a>
                                            <a href="/finanzierungsberatung.html" class="{% if currentUrl == '/finanzierungsberatung.html' %}{{ mobileActiveClass }}{% else %}{{ mobileDefaultClass }}{% endif %}">Finanzierung</a>
                                            {#
                                            <a href="/verwaltung.html" class="{% if currentUrl == '/verwaltung.html' %}{{ mobileActiveClass }}{% else %}{{ mobileDefaultClass }}{% endif %}">Verwaltung</a>
                                            #}
                                            <a href="/verkaufen.html" class="{% if currentUrl == '/verkaufen.html' %}{{ mobileActiveClass }}{% else %}{{ mobileDefaultClass }}{% endif %}">Verkaufen</a>
                                            <a href="/ueber-uns.html" class="{% if currentUrl == '/ueber-uns.html' %}{{ mobileActiveClass }}{% else %}{{ mobileDefaultClass }}{% endif %}">Über uns</a>
                                            <a href="/index.html#kontakt" class="{{ mobileDefaultClass }}">Kontakt</a>
                                        </div>
                                    </div>
                                </nav>

<main>{{ content | safe }}</main>


<footer class="bg-gray-900 text-white py-8">
    <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-center">
            <div class="text-2xl font-bold">
                                        <a href="/index.html" class="flex items-center">
                                            <img src="/images/fg-logo-gold-transparent.png" alt="Fischer & Geserich Real Estate" class="fg-header-logo" width="54" height="54">
                                            <span class="hidden md:inline">Fischer & Geserich Real Estate</span>
                                                                      
                                            <span class="md:hidden">F&G Real Estate</span>
                                        </a>
                        </div>

            <div class="flex space-x-6">
                <a href="https://www.linkedin.com/company/fischer-geserich-real-estate-gmbh/" class="text-gray-400 hover:text-accent transition duration-300">
                    <i class="fab fa-linkedin-in text-xl"></i>
                </a>
                <a href="https://www.instagram.com/fg.immobilien/" class="text-gray-400 hover:text-accent transition duration-300">
                    <i class="fab fa-instagram text-xl"></i>
                </a>
            </div>
        </div>

        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400 text-sm">
            <p>
                &copy; 2026 Fischer & Geserich Real Estate GmbH. Alle Rechte vorbehalten.
            </p>
            <p class="mt-2">
                <a href="/impressum.html" class="hover:text-accent hover:underline transition duration-300">Impressum</a>
                <span class="mx-2 text-gray-600">|</span>
                <a href="/datenschutz.html" class="hover:text-accent hover:underline transition duration-300">Datenschutz</a>
                <span class="mx-2 text-gray-600">|</span>
                <a href="/agb.html" class="hover:text-accent hover:underline transition duration-300">AGB</a>
                <span class="mx-2 text-gray-600">|</span>
                <a href="#" data-open-consent class="hover:text-accent hover:underline transition duration-300">Cookie-Einstellungen</a>
            </p>
        </div>
    </div>
</footer>



<script>
    const mobileMenuBtn = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
    });
    
    
</script>



<script src="/script.js"></script>
</body>
</html>
