<section id="terminbuchung" class="appointment-quiz-section container mx-auto px-4 py-10 md:py-14">
  <div class="appointment-quiz-shell">
    <div class="appointment-quiz-left">
      <div class="appointment-left-bg"></div>

      <div class="appointment-left-content">
        <p class="appointment-kicker">Direkte Terminbuchung</p>
        <h2>Termin für Ihre Ankaufsberatung auswählen.</h2>
        <p>
          Schritt für Schritt zum passenden Termin. Wir prüfen Ihren Wunsch im Propstack-Kalender
          und bestätigen den Termin persönlich über info@fg-realestate.de.
        </p>

        <div class="appointment-steps-preview">
          <div class="appointment-preview-item is-active" data-preview-step="1">
            <span>1</span>
            <div>
              <strong>Terminart</strong>
              <small>Kapitalanlage, Eigennutzung oder Beratung</small>
            </div>
          </div>

          <div class="appointment-preview-item" data-preview-step="2">
            <span>2</span>
            <div>
              <strong>Wunschtermin</strong>
              <small>Datum und verfügbare Uhrzeit auswählen</small>
            </div>
          </div>

          <div class="appointment-preview-item" data-preview-step="3">
            <span>3</span>
            <div>
              <strong>Kontaktdaten</strong>
              <small>Damit wir den Termin bestätigen können</small>
            </div>
          </div>

          <div class="appointment-preview-item" data-preview-step="4">
            <span>4</span>
            <div>
              <strong>Anliegen</strong>
              <small>Kurze Einordnung für die Vorbereitung</small>
            </div>
          </div>
        </div>

        <div class="appointment-note-card">
          <i class="fas fa-shield-alt"></i>
          <span>Ihre Anfrage wird im CRM gespeichert und persönlich geprüft.</span>
        </div>
      </div>
    </div>

    <div class="appointment-quiz-right">
      <div class="appointment-progress-wrap">
        <div>
          <p class="appointment-step-label">Schritt <span class="appointment-current-step">1</span> von 4</p>
          <h3 class="appointment-step-title">Welche Beratung wünschen Sie?</h3>
        </div>
        <div class="appointment-progress">
          <span style="width:25%"></span>
        </div>
      </div>

      <div class="appointment-success hidden">
        <h4>Terminwunsch wurde übermittelt.</h4>
        <p>Wir melden uns zeitnah persönlich mit einer Bestätigung.</p>
      </div>

      <div class="appointment-error hidden">
        <h4>Terminwunsch konnte nicht gesendet werden.</h4>
        <p>Bitte versuchen Sie es erneut oder kontaktieren Sie uns direkt per E-Mail.</p>
      </div>

      <form class="appointment-quiz-form">
        <input type="hidden" name="topic" value="">
        <input type="hidden" name="date" value="">
        <input type="hidden" name="time" value="">
        <input type="hidden" name="source_url" value="">

        <div class="appointment-quiz-step" data-step="1">
          <div class="appointment-choice-grid">
            <button type="button" class="appointment-choice" data-field="topic" data-value="Kapitalanlage">
              <i class="fas fa-chart-line"></i>
              <span>
                <strong>Für Kapitalanleger</strong>
                <small>Rendite, Objektprüfung und Investmentstrategie</small>
              </span>
            </button>

            <button type="button" class="appointment-choice" data-field="topic" data-value="Eigennutzung">
              <i class="fas fa-home"></i>
              <span>
                <strong>Für Eigennutzer</strong>
                <small>Kaufberatung für die eigene Immobilie</small>
              </span>
            </button>

            <button type="button" class="appointment-choice" data-field="topic" data-value="Finanzierung">
              <i class="fas fa-euro-sign"></i>
              <span>
                <strong>Finanzierung</strong>
                <small>Budget, Banktermin und Finanzierungsvorbereitung</small>
              </span>
            </button>

            <button type="button" class="appointment-choice" data-field="topic" data-value="Allgemeine Ankaufsberatung">
              <i class="fas fa-comments"></i>
              <span>
                <strong>Allgemeine Beratung</strong>
                <small>Erstgespräch zur passenden Kaufstrategie</small>
              </span>
            </button>
          </div>
        </div>

        <div class="appointment-quiz-step hidden" data-step="2">
          <div class="appointment-date-layout">
            <div class="appointment-field">
              <label>Wunschtermin auswählen *</label>
              <input type="date" class="appointment-date-input" required>
              <small>Verfügbare Uhrzeiten werden danach geladen.</small>
            </div>

            <div class="appointment-slots">
              <p class="appointment-slots-title">Freie Uhrzeiten</p>
              <div class="appointment-slot-list">
                <button type="button" class="appointment-slot-placeholder" disabled>Bitte zuerst ein Datum wählen</button>
              </div>
              <p class="appointment-slot-hint">
                Die Live-Verfügbarkeiten werden im nächsten Schritt über Propstack angebunden.
              </p>
            </div>
          </div>
        </div>

        <div class="appointment-quiz-step hidden" data-step="3">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="appointment-field">
              <label>Vorname *</label>
              <input type="text" name="first_name" required placeholder="Vorname">
            </div>

            <div class="appointment-field">
              <label>Nachname *</label>
              <input type="text" name="last_name" required placeholder="Nachname">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
            <div class="appointment-field">
              <label>E-Mail-Adresse *</label>
              <input type="email" name="email" required placeholder="name@email.de">
            </div>

            <div class="appointment-field">
              <label>Telefonnummer</label>
              <input type="tel" name="phone" placeholder="Telefonnummer">
            </div>
          </div>
        </div>

        <div class="appointment-quiz-step hidden" data-step="4">
          <div class="appointment-field">
            <label>Objektadresse oder Suchgebiet</label>
            <input type="text" name="location" placeholder="z. B. Berlin, Potsdam oder konkrete Objektadresse">
          </div>

          <div class="appointment-field mt-4">
            <label>Worum geht es konkret?</label>
            <textarea name="message" rows="5" placeholder="z. B. Ich möchte eine Eigentumswohnung als Kapitalanlage prüfen lassen oder suche eine Immobilie zur Eigennutzung."></textarea>
          </div>

          <label class="appointment-consent mt-4">
            <input type="checkbox" name="privacy_consent" value="true" required>
            <span>
              Ich habe die <a href="/datenschutz.html" target="_blank">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Angaben zur Terminbearbeitung zu. *
            </span>
          </label>
        </div>

        <div class="appointment-actions">
          <button type="button" class="appointment-back hidden">Zurück</button>
          <button type="button" class="appointment-next">Weiter</button>
          <button type="submit" class="appointment-submit hidden">Terminwunsch senden</button>
        </div>
      </form>
    </div>
  </div>
</section>

