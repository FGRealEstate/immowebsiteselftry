---
layout: base.njk
---

<div class="w-full py-16 bg-page-bg">
    
    <div class="container mx-auto px-4">

        <a href="/angebote.html" class="inline-block mb-8 text-primary hover:text-secondary font-semibold transition duration-300">
            <i class="fas fa-arrow-left mr-2"></i> Zurück zu den Angeboten
        </a>

        <div class="bg-white rounded-xl shadow-2xl overflow-hidden p-6 md:p-10">

            <header class="mb-8 border-b pb-4 border-gray-100">
                <div class="flex flex-wrap gap-2 mb-3">
                    <span class="inline-block bg-secondary text-primary text-sm font-bold px-4 py-1 rounded-full">{{ status }}</span>
                    <span class="inline-block border border-primary text-primary text-sm font-semibold px-4 py-1 rounded-full">{{ vermarktungsart }}</span>
                </div>
               
                <h1 class="text-4xl font-extrabold text-gold-gradient with-shadow mb-2">{{ titel }}</h1>
                <p class="text-xl text-gray-600"><i class="fas fa-map-marker-alt mr-2 text-accent"></i> {{ ort }}</p>
            </header>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

                <div class="lg:col-span-2">
                    
                    <div class="relative mb-4">
                        <img id="mainImage" src="{{ hauptbild }}" alt="Hauptbild von {{ titel }}" 
                             class="w-full h-[400px] md:h-[500px] object-cover rounded-lg shadow-lg border border-gray-200 transition-opacity duration-300">
                    </div>

                    {% if galerie and galerie.length > 0 %}
                    <div class="grid grid-cols-4 md:grid-cols-6 gap-2 mb-8">
                        <div class="cursor-pointer overflow-hidden rounded-md border-2 border-accent shadow-sm hover:opacity-80 transition"
                             onclick="changeImage('{{ hauptbild }}', this)">
                            <img src="{{ hauptbild }}" class="w-full h-16 md:h-20 object-cover">
                        </div>

                        {% for item in galerie %}
                        <div class="cursor-pointer overflow-hidden rounded-md border-2 border-transparent shadow-sm hover:opacity-80 transition"
                             onclick="changeImage('{{ item.bild }}', this)">
                            <img src="{{ item.bild }}" alt="Galeriebild" class="w-full h-16 md:h-20 object-cover">
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    <h2 class="text-2xl font-bold text-primary mb-4 border-b border-secondary/50 pb-2">Objektbeschreibung</h2>

                    <div class="prose max-w-none text-gray-700 leading-relaxed">
                        {{ content | raw }}
                    </div>
                </div>

                <div class="lg:col-span-1 space-y-8">

                    <div class="bg-gray-50 p-6 rounded-lg shadow-inner border border-gray-100">
                        <h3 class="text-xl font-bold text-primary mb-4 border-b border-accent/50 pb-2">Wichtige Eckdaten</h3>
                        
                        <ul class="space-y-3 text-gray-700">
                            <li class="flex justify-between border-b border-gray-200 pb-2">
                                <span class="font-semibold text-primary">Objektart:</span>
                                <span>{{ objektart }}</span>
                            </li>
       
                            <li class="flex justify-between border-b border-gray-200 pb-2">
                                <span class="font-semibold text-primary">Wohnfläche:</span>
                                <span>{{ eckdaten.flaeche }} m²</span>
                            </li>
                            
                            <li class="flex justify-between border-b border-gray-200 pb-2">
                                <span class="font-semibold text-primary">Zimmer:</span>
                                <span>{{ eckdaten.zimmer }}</span>
                            </li>
                            
                            <li class="flex justify-between border-b border-gray-200 pb-2">
                                <span class="font-semibold text-primary">Baujahr:</span>
                                <span>{{ eckdaten.baujahr }}</span>
                            </li>
                            
                            {% if provision %}
                            <li class="flex justify-between border-b border-gray-200 pb-2">
                                <span class="font-semibold text-primary">Provision:</span>
                                <span class="text-sm text-right max-w-[50%]">{{ provision }}</span>
                            </li>
                            {% endif %}

                            <li class="flex justify-between pt-2 items-center">
                                <span class="font-bold text-primary text-lg">Preis:</span>
                                <span class="text-gold-gradient with-shadow font-extrabold text-xl">€ {{ preis }}</span>
                            </li>
                        </ul>
                    </div>

                    <div class="p-6 bg-primary text-white rounded-lg text-center shadow-lg">
                        <h3 class="text-2xl font-bold text-accent mb-3">Interesse?</h3>
                        <p class="mb-6 text-secondary">Vereinbaren Sie noch heute einen Besichtigungstermin für dieses Objekt.</p>
                        
                        <a href="/index.html#kontakt" class="btn-85 w-full block text-center text-primary font-bold py-3 rounded-lg transition duration-300">
                            Kontakt aufnehmen
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<script>
    function changeImage(src, el) {
        const mainImg = document.getElementById('mainImage');
        mainImg.style.opacity = '0';
        
        setTimeout(() => {
            mainImg.src = src;
            mainImg.style.opacity = '1';
        }, 200);

        const thumbs = el.parentElement.children;
        for (let t of thumbs) {
            t.classList.remove('border-accent');
            t.classList.add('border-transparent');
        }
        el.classList.add('border-accent');
        el.classList.remove('border-transparent');
    }
</script>