---
layout: base.njk
title: Angebote – Das Team von Fischer & Geserich Real Estate
permalink: angebote.html
---

<section class="bg-primary text-white py-16 md:py-24">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-3">
            Aktuelle Immobilien-Angebote
        </h1>

        <p class="text-lg md:text-xl font-light text-secondary max-w-4xl mx-auto">
            Ob Eigentumswohnung, Mehrfamilienhaus oder Grundstück – wir vermarkten Immobilien mit maximaler Reichweite und Effizienz.
        </p>
    </div>
</section>

<section id="angebote" class="container mx-auto px-4 py-16">

    <div class="bg-white p-6 rounded-lg shadow-xl mb-10 border-t-4 border-accent">
        <h2 class="text-2xl font-bold mb-4 text-primary">
            Ihre Immobiliensuche
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <select id="filter-vermarktung" class="p-3 border border-gray-300 rounded focus:border-primary focus:ring-primary">
                <option value="">Vermarktungsart (Alle)</option>
                {% for type in propstack.filters.marketingTypes %}
                <option value="{{ type }}">{{ type }}</option>
                {% endfor %}
            </select>

            <select id="filter-objektart" class="p-3 border border-gray-300 rounded focus:border-primary focus:ring-primary">
                <option value="">Objektart (Alle)</option>
                {% for type in propstack.filters.propertyTypes %}
                <option value="{{ type }}">{{ type }}</option>
                {% endfor %}
            </select>

            <input
                type="text"
                id="filter-preis"
                inputmode="numeric"
                placeholder="Max. Kaufpreis (€)"
                class="p-3 border border-gray-300 rounded focus:border-primary focus:ring-primary"
            >

            <button id="filter-button" class="btn-85 text-primary font-bold rounded py-3 hover:bg-primary hover:text-white transition duration-300 w-full">
                <i class="fas fa-search mr-2"></i> Suchen
            </button>
        </div>

        <div class="mt-4 flex flex-wrap gap-3">
            <button id="filter-reset" type="button" class="text-sm text-primary font-semibold hover:underline">
                Filter zurücksetzen
            </button>
        </div>
    </div>

    <h2 class="text-3xl font-bold mb-8 text-primary border-b-2 border-secondary pb-2">
        Aktuelle Objekte (<span id="object-count">{{ propstack.properties | length }}</span>)
    </h2>

    {% if propstack.properties and propstack.properties.length %}

    <div id="property-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        {% for property in propstack.properties %}
        <div
            class="immobilien-kachel property-card bg-white rounded-lg shadow-xl overflow-hidden transition duration-300 hover:shadow-2xl hover:-translate-y-1"
            data-vermarktung="{{ property.marketing_type or '' }}"
            data-objektart="{{ property.property_type or '' }}"
            data-preis="{{ property.price_raw or '' }}"
        >

            <a href="{{ property.url }}" class="block bg-gray-100 overflow-hidden">
                {% if property.main_image %}
                <img
                    src="{{ property.main_image }}"
                    alt="{{ property.title }}"
                    class="w-full h-56 object-cover transition duration-300 hover:scale-105"
                >
                {% else %}
                <div class="w-full h-56 flex items-center justify-center bg-gray-100 text-gray-400">
                    <i class="fas fa-home text-5xl"></i>
                </div>
                {% endif %}
            </a>

            <div class="p-5">

                <div class="flex justify-between items-center mb-3 gap-3">
                    {% if property.marketing_type %}
                    <span class="inline-block bg-secondary text-primary text-xs font-semibold px-3 py-1 rounded-full">
                        {{ property.marketing_type }}
                    </span>
                    {% endif %}

                    {% if property.property_type %}
                    <span class="text-xs text-gray-500 font-semibold text-right">
                        {{ property.property_type }}
                    </span>
                    {% endif %}
                </div>

                <h3 class="text-xl font-bold text-primary mb-2 line-clamp-2 min-h-[3.5rem]">
                    {{ property.title }}
                </h3>

                {% if property.location %}
                <p class="text-sm text-gray-600 mb-4">
                    <i class="fas fa-map-marker-alt mr-1 text-accent"></i>
                    {{ property.location }}
                </p>
                {% endif %}

                <p class="text-2xl font-extrabold text-gold-gradient with-shadow mb-4">
                    {{ property.price or "Preis auf Anfrage" }}
                </p>

                {% if property.living_space or property.rooms %}
                <div class="flex justify-between text-sm text-gray-600 mb-6 border-t border-gray-100 pt-3 gap-3">
                    {% if property.living_space %}
                    <span>
                        <i class="fas fa-ruler-combined mr-1 text-accent"></i>
                        {{ property.living_space }}
                    </span>
                    {% endif %}

                    {% if property.rooms %}
                    <span>
                        <i class="fas fa-bed mr-1 text-accent"></i>
                        {{ property.rooms }} Zi.
                    </span>
                    {% endif %}
                </div>
                {% endif %}

                <a href="{{ property.url }}" class="btn-85 block text-center text-primary font-bold py-2 rounded-lg transition duration-300">
                    Mehr erfahren
                </a>

            </div>
        </div>
        {% endfor %}

    </div>

    <div id="pagination" class="flex justify-center items-center gap-2 mt-10"></div>

    <div id="no-results" class="hidden text-center py-12">
        <p class="text-xl text-gray-600 mb-4">
            Für Ihre Suche wurden keine passenden Immobilien gefunden.
        </p>
    </div>

    {% else %}

    <div class="text-center py-12">
        <p class="text-xl text-gray-600 mb-4">
            Aktuell sind keine Immobilienangebote online verfügbar.
        </p>

        <p class="text-gray-500">
            Kontaktieren Sie uns direkt für Off-Market Angebote.
        </p>
    </div>

    {% endif %}

</section>

<section id="maklerei" class="bg-gray-100 py-16">
    <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-10 text-primary">
            Ihre Vorteile im Vertrieb mit Fischer & Geserich
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

            <div>
                <p class="text-lg text-gray-700 mb-6">
                    Wir decken die gesamte Palette ab: vom klassischen Einfamilienhaus bis hin zu komplexen Projektentwicklungen. Unser Ziel ist die maximale Wertschöpfung für Sie, kombiniert mit einem schnellen und sicheren Verkaufsprozess.
                </p>

                <p class="text-lg text-gray-700 mb-8 font-semibold text-primary">
                    Verlassen Sie sich auf unsere Expertise – deutschlandweit.
                </p>

                <a href="#cta-gesuch" class="btn-85 inline-block text-primary font-bold py-3 px-8 rounded-lg shadow-md transition duration-300">
                    Gesuch anlegen
                </a>
            </div>

            <ul class="space-y-4 text-lg text-gray-700">
                <li class="flex items-start">
                    <i class="fas fa-check-circle text-gold-gradient with-shadow mt-1 mr-3 text-xl"></i>
                    Professionelle Immobilienbewertung zur Festlegung des optimalen Marktpreises.
                </li>

                <li class="flex items-start">
                    <i class="fas fa-check-circle text-gold-gradient with-shadow mt-1 mr-3 text-xl"></i>
                    Interner Bonitätscheck: Jeder Interessent wird vor der Besichtigung auf Bonität geprüft.
                </li>

                <li class="flex items-start">
                    <i class="fas fa-check-circle text-gold-gradient with-shadow mt-1 mr-3 text-xl"></i>
                    High-End-Vermarktung inklusive professioneller Fotos, Drohnenaufnahmen und Präsenz auf allen relevanten Portalen.
                </li>

                <li class="flex items-start">
                    <i class="fas fa-check-circle text-gold-gradient with-shadow mt-1 mr-3 text-xl"></i>
                    Effiziente Besichtigungen mit geprüften Interessenten und diskreter Abwicklung.
                </li>

                <li class="flex items-start">
                    <i class="fas fa-check-circle text-gold-gradient with-shadow mt-1 mr-3 text-xl"></i>
                    Vollständige Vertragsabwicklung bis hin zur Begleitung des Notartermins.
                </li>

                <li class="flex items-start">
                    <i class="fas fa-check-circle text-gold-gradient with-shadow mt-1 mr-3 text-xl"></i>
                    Diskrete Off-Market-Vermarktung über unser Netzwerk geprüfter Investoren.
                </li>
            </ul>

        </div>
    </div>
</section>

<section id="cta-gesuch" class="bg-primary py-16 md:py-24 border-t border-accent/20">
    <div class="container mx-auto px-4 text-center">
        <div class="max-w-4xl mx-auto">

            <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gold-gradient with-shadow">
                Das passende Objekt nicht gefunden?
            </h2>

            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="index.html#kontakt" class="btn-85 inline-block font-bold py-4 px-10 text-lg rounded-lg shadow-xl transition duration-300 transform hover:scale-105">
                    Jetzt Gesuch anlegen
                </a>
            </div>

        </div>
    </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const cards = Array.from(document.querySelectorAll(".property-card"));
    const marketingFilter = document.getElementById("filter-vermarktung");
    const typeFilter = document.getElementById("filter-objektart");
    const priceInput = document.getElementById("filter-preis");
    const filterButton = document.getElementById("filter-button");
    const resetButton = document.getElementById("filter-reset");
    const countLabel = document.getElementById("object-count");
    const pagination = document.getElementById("pagination");
    const noResults = document.getElementById("no-results");

    const perPage = 9;
    let currentPage = 1;
    let filteredCards = cards;

    function parseGermanNumber(value) {
        if (!value) return null;

        const clean = String(value)
            .replace(/\s/g, "")
            .replace(/€/g, "")
            .replace(/\./g, "")
            .replace(",", ".")
            .replace(/[^\d.]/g, "");

        if (!clean) return null;

        const number = Number(clean);

        if (Number.isNaN(number)) return null;

        return number;
    }

    function formatGermanNumber(value) {
        const number = parseGermanNumber(value);

        if (!number) return "";

        return new Intl.NumberFormat("de-DE", {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(number);
    }

    function getCardPrice(card) {
        const raw = card.dataset.preis;

        if (!raw) return null;

        const number = Number(raw);

        if (Number.isNaN(number)) return null;

        return number;
    }

    function applyFilters() {
        const marketing = marketingFilter ? marketingFilter.value : "";
        const type = typeFilter ? typeFilter.value : "";
        const maxPrice = priceInput ? parseGermanNumber(priceInput.value) : null;

        filteredCards = cards.filter(function (card) {
            const cardMarketing = card.dataset.vermarktung || "";
            const cardType = card.dataset.objektart || "";
            const cardPrice = getCardPrice(card);

            const marketingMatch = !marketing || cardMarketing === marketing;
            const typeMatch = !type || cardType === type;

            let priceMatch = true;

            if (maxPrice && cardPrice) {
                priceMatch = cardPrice <= maxPrice;
            }

            if (maxPrice && !cardPrice) {
                priceMatch = false;
            }

            return marketingMatch && typeMatch && priceMatch;
        });

        currentPage = 1;
        render();
    }

    function render() {
        cards.forEach(function (card) {
            card.style.display = "none";
        });

        const start = (currentPage - 1) * perPage;
        const end = start + perPage;

        filteredCards.slice(start, end).forEach(function (card) {
            card.style.display = "";
        });

        if (countLabel) {
            countLabel.textContent = filteredCards.length;
        }

        if (noResults) {
            noResults.classList.toggle("hidden", filteredCards.length !== 0);
        }

        renderPagination();
    }

    function renderPagination() {
        if (!pagination) return;

        pagination.innerHTML = "";

        const pages = Math.ceil(filteredCards.length / perPage);

        if (pages <= 1) return;

        const previousButton = document.createElement("button");
        previousButton.type = "button";
        previousButton.innerHTML = '<i class="fas fa-chevron-left"></i>';
        previousButton.className = currentPage === 1
            ? "px-4 py-2 rounded bg-gray-200 text-gray-400 font-bold cursor-not-allowed"
            : "px-4 py-2 rounded bg-white text-primary font-bold shadow hover:bg-gray-100";

        previousButton.disabled = currentPage === 1;

        previousButton.addEventListener("click", function () {
            if (currentPage > 1) {
                currentPage -= 1;
                render();
                document.getElementById("angebote").scrollIntoView({ behavior: "smooth" });
            }
        });

        pagination.appendChild(previousButton);

        for (let i = 1; i <= pages; i++) {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = i;
            button.className = i === currentPage
                ? "px-4 py-2 rounded bg-primary text-white font-bold"
                : "px-4 py-2 rounded bg-white text-primary font-bold shadow hover:bg-gray-100";

            button.addEventListener("click", function () {
                currentPage = i;
                render();
                document.getElementById("angebote").scrollIntoView({ behavior: "smooth" });
            });

            pagination.appendChild(button);
        }

        const nextButton = document.createElement("button");
        nextButton.type = "button";
        nextButton.innerHTML = '<i class="fas fa-chevron-right"></i>';
        nextButton.className = currentPage === pages
            ? "px-4 py-2 rounded bg-gray-200 text-gray-400 font-bold cursor-not-allowed"
            : "px-4 py-2 rounded bg-white text-primary font-bold shadow hover:bg-gray-100";

        nextButton.disabled = currentPage === pages;

        nextButton.addEventListener("click", function () {
            if (currentPage < pages) {
                currentPage += 1;
                render();
                document.getElementById("angebote").scrollIntoView({ behavior: "smooth" });
            }
        });

        pagination.appendChild(nextButton);
    }

    if (priceInput) {
        priceInput.addEventListener("blur", function () {
            priceInput.value = formatGermanNumber(priceInput.value);
        });

        priceInput.addEventListener("keydown", function (event) {
            if (event.key === "Enter") {
                priceInput.value = formatGermanNumber(priceInput.value);
                applyFilters();
            }
        });

        priceInput.addEventListener("input", function () {
            const cursorPosition = priceInput.selectionStart;
            const raw = priceInput.value;

            if (!raw) return;

            const allowed = raw.replace(/[^\d.,]/g, "");

            if (raw !== allowed) {
                priceInput.value = allowed;
                priceInput.setSelectionRange(cursorPosition - 1, cursorPosition - 1);
            }
        });
    }

    if (filterButton) {
        filterButton.addEventListener("click", function () {
            if (priceInput) {
                priceInput.value = formatGermanNumber(priceInput.value);
            }

            applyFilters();
        });
    }

    if (marketingFilter) {
        marketingFilter.addEventListener("change", applyFilters);
    }

    if (typeFilter) {
        typeFilter.addEventListener("change", applyFilters);
    }

    if (resetButton) {
        resetButton.addEventListener("click", function () {
            if (marketingFilter) marketingFilter.value = "";
            if (typeFilter) typeFilter.value = "";
            if (priceInput) priceInput.value = "";

            filteredCards = cards;
            currentPage = 1;
            render();
        });
    }

    render();
});
</script>
