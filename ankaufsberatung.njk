<script>
function initializeAccordion(containerId) {
  const container = document.getElementById(containerId);
  if (!container || container.dataset.initialized === 'true') return;

  const items = container.querySelectorAll('.accordion-item');

  items.forEach(item => {
    const header = item.querySelector('.accordion-header');
    const content = item.querySelector('.accordion-content');
    const icon = item.querySelector('.accordion-header i');

    if (item.dataset.open === 'true') {
      content.classList.remove('hidden');
      if (icon) icon.classList.add('rotate-180');
    } else {
      content.classList.add('hidden');
      if (icon) icon.classList.remove('rotate-180');
    }

    header.addEventListener('click', () => {
      const isOpen = !content.classList.contains('hidden');

      items.forEach(other => {
        if (other !== item) {
          other.querySelector('.accordion-content').classList.add('hidden');
          other.dataset.open = 'false';
          const otherIcon = other.querySelector('.accordion-header i');
          if (otherIcon) otherIcon.classList.remove('rotate-180');
        }
      });

      if (isOpen) {
        content.classList.add('hidden');
        item.dataset.open = 'false';
        if (icon) icon.classList.remove('rotate-180');
      } else {
        content.classList.remove('hidden');
        item.dataset.open = 'true';
        if (icon) icon.classList.add('rotate-180');
      }
    });
  });

  container.dataset.initialized = 'true';
}

function switchTab(type) {
  const slider = document.getElementById('tab-slider');
  const btnKapital = document.getElementById('btn-kapitalanleger');
  const btnEigen = document.getElementById('btn-eigennutzer');
  const contentKapital = document.getElementById('content-kapitalanleger');
  const contentEigen = document.getElementById('content-eigennutzer');
  const ctaTitle = document.getElementById('cta-title');
  const ctaText = document.getElementById('cta-text');
  const ctaButton = document.getElementById('cta-button');

  if (type === 'kapitalanleger') {
    slider.style.transform = 'translateX(0)';
    btnKapital.classList.remove('text-gray-500');
    btnKapital.classList.add('text-primary');
    btnEigen.classList.remove('text-primary');
    btnEigen.classList.add('text-gray-500');
    contentKapital.classList.remove('hidden');
    contentEigen.classList.add('hidden');
    ctaTitle.textContent = 'Investment-Gespräch vereinbaren';
    ctaText.textContent = 'Buchen Sie jetzt Ihr unverbindliches Erstgespräch, um Ihre Investmentstrategie und den weiteren Fahrplan zu definieren.';
    ctaButton.innerHTML = '<i class="fas fa-calendar-check mr-2"></i> Termin für Kapitalanleger auswählen';
    initializeAccordion('accordion-investor');
  } else {
    slider.style.transform = 'translateX(100%) translateX(4px)';
    btnEigen.classList.remove('text-gray-500');
    btnEigen.classList.add('text-primary');
    btnKapital.classList.remove('text-primary');
    btnKapital.classList.add('text-gray-500');
    contentEigen.classList.remove('hidden');
    contentKapital.classList.add('hidden');
    ctaTitle.textContent = 'Erstgespräch vereinbaren';
    ctaText.textContent = 'Der erste Schritt in Ihr neues Zuhause: Buchen Sie jetzt Ihr unverbindliches Gespräch zur Profilerstellung.';
    ctaButton.innerHTML = '<i class="fas fa-calendar-check mr-2"></i> Termin für Eigennutzer auswählen';
    initializeAccordion('accordion-owner');
  }
}

document.addEventListener('DOMContentLoaded', () => {
  switchTab('kapitalanleger');
});
</script>

