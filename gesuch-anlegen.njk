</style>

<script>
(function(){
  const form = document.getElementById('fg-search-profile-form');
  if(!form) return;
  const steps = Array.from(form.querySelectorAll('.fg-step'));
  const back = document.getElementById('fg-back');
  const next = document.getElementById('fg-next');
  const submit = document.getElementById('fg-submit');
  const label = document.getElementById('fg-step-label');
  const bar = document.getElementById('fg-progress-bar');
  const success = form.querySelector('.fg-success');
  const errorBox = form.querySelector('.fg-error');
  let current = 0;

  function showStep(){
    steps.forEach((s,i)=>s.classList.toggle('is-active', i===current));
    back.disabled = current === 0;
    next.hidden = current === steps.length - 1;
    submit.hidden = current !== steps.length - 1;
    label.textContent = `Schritt ${current + 1} von ${steps.length}`;
    bar.style.width = `${((current + 1) / steps.length) * 100}%`;
  }

  function validCurrent(){
    const required = Array.from(steps[current].querySelectorAll('[required]'));
    for(const field of required){
      if((field.type === 'checkbox' && !field.checked) || !field.value){ field.reportValidity(); return false; }
    }
    return true;
  }

  function moneyFormat(input){
    const raw = input.value.replace(/[^0-9,.]/g, '');
    const n = Number(raw.replace(/\./g, '').replace(',', '.'));
    if(!Number.isNaN(n) && n > 0){ input.value = new Intl.NumberFormat('de-DE',{style:'currency',currency:'EUR',minimumFractionDigits:2,maximumFractionDigits:2}).format(n); }
  }
  form.querySelectorAll('.js-money').forEach(i=>{ i.addEventListener('input',()=>i.value=i.value.replace(/[^\d.,]/g,'')); i.addEventListener('blur',()=>moneyFormat(i)); });
  form.querySelectorAll('.js-number').forEach(i=>i.addEventListener('input',()=>i.value=i.value.replace(/[^\d.,]/g,'')));

  next.addEventListener('click',()=>{ if(!validCurrent()) return; current=Math.min(current+1,steps.length-1); showStep(); });
  back.addEventListener('click',()=>{ current=Math.max(current-1,0); showStep(); });

  form.addEventListener('submit', async (e)=>{
    e.preventDefault();
    if(!validCurrent()) return;
    success.hidden = true; errorBox.hidden = true; submit.disabled = true; submit.textContent = 'Wird übermittelt...';
    const fd = new FormData(form); const params = new URLSearchParams(location.search);
    const features = fd.getAll('features');
    const payload = {
      first_name: fd.get('first_name'), last_name: fd.get('last_name'), email: fd.get('email'), phone: fd.get('phone'),
      marketing_type: fd.get('marketing_type'), property_type: fd.get('property_type'), location: fd.get('location'), budget: fd.get('budget'), rooms: fd.get('rooms'), living_space: fd.get('living_space'), bedrooms: fd.get('bedrooms'), bathrooms: fd.get('bathrooms'), plot_area: fd.get('plot_area'), features, message: fd.get('message'),
      privacy_consent: fd.get('privacy_consent') === 'true', newsletter_consent: true, source_url: location.href,
      utm_source: params.get('utm_source') || '', utm_medium: params.get('utm_medium') || '', utm_campaign: params.get('utm_campaign') || '', utm_content: params.get('utm_content') || '', utm_term: params.get('utm_term') || ''
    };
    try{
      const res = await fetch('/.netlify/functions/propstack-search-profile',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)});
      const result = await res.json();
      if(!res.ok || !result.success) throw new Error(result.error || 'Fehler');
      form.reset(); current = 0; showStep(); success.hidden = false; window.scrollTo({top:0,behavior:'smooth'});
    }catch(err){ console.error(err); errorBox.hidden = false; }
    finally{ submit.disabled = false; submit.textContent = 'Gesuch übermitteln'; }
  });

  if(window.google && google.maps && google.maps.places){
    form.querySelectorAll('.google-address').forEach(function(input){
      const ac = new google.maps.places.Autocomplete(input,{types:['(regions)'],componentRestrictions:{country:'de'}});
      ac.addListener('place_changed',()=>{ const p=ac.getPlace(); if(p && p.formatted_address) input.value=p.formatted_address; });
    });
  }
  showStep();
})();
</script>
